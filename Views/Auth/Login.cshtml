@{
    Layout = null;
    bool showReg = TempData["ShowReg"] != null;
    string loginActive = showReg ? "" : "active";
    string regActive   = showReg ? "active" : "";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>VSMS - Login</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #0d6efd 0%, #0a58ca 100%);
            min-height: 100vh;
            display: flex; align-items: center; justify-content: center;
            overflow: hidden; position: relative;
        }
        .shape {
            position: absolute; border-radius: 50%;
            background: rgba(255,255,255,0.1);
            animation: float 15s infinite ease-in-out; z-index: 0;
        }
        .shape-1 { width: 400px; height: 400px; top: -100px; left: -100px; }
        .shape-2 { width: 300px; height: 300px; bottom: -50px; right: -50px; animation-delay: -5s; }
        .shape-3 { width: 150px; height: 150px; top: 40%; left: 60%; animation-delay: -10s; }
        @@keyframes float {
            0%,100% { transform: translateY(0) rotate(0deg); }
            50%      { transform: translateY(-20px) rotate(10deg); }
        }
        .login-card {
            background: rgba(255,255,255,0.97);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.2);
            padding: 40px; width: 100%; max-width: 460px; z-index: 1;
            animation: slideUp 0.8s cubic-bezier(0.16,1,0.3,1) forwards;
        }
        @@keyframes slideUp {
            from { opacity: 0; transform: translateY(40px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        .login-icon {
            width: 80px; height: 80px; background: #e9ecef;
            border-radius: 50%; display: flex; align-items: center; justify-content: center;
            margin: 0 auto 20px; font-size: 32px; color: #0d6efd;
            box-shadow: 0 8px 16px rgba(13,110,253,0.2);
        }
        .tab-switcher {
            display: flex; background: #f1f5f9;
            border-radius: 12px; padding: 4px; margin-bottom: 24px;
        }
        .tab-btn {
            flex: 1; border: none; background: transparent; border-radius: 9px;
            padding: 10px 0; font-weight: 600; font-size: 0.875rem;
            color: #64748b; cursor: pointer; transition: all 0.25s;
        }
        .tab-btn.active { background: white; color: #0d6efd; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
        .input-wrap { position: relative; margin-bottom: 16px; }
        .input-wrap i {
            position: absolute; left: 15px; top: 50%;
            transform: translateY(-50%); color: #adb5bd; z-index: 5;
        }
        .form-control {
            border-radius: 10px; padding: 12px 15px 12px 45px;
            border: 1px solid #dee2e6; transition: all 0.3s; width: 100%;
        }
        .form-control:focus {
            box-shadow: 0 0 0 4px rgba(13,110,253,0.15);
            border-color: #0d6efd; outline: none;
        }
        .btn-submit {
            border-radius: 10px; padding: 12px; font-weight: 600;
            font-size: 16px; transition: all 0.3s; width: 100%; margin-top: 6px;
        }
        .btn-submit:hover { transform: translateY(-2px); box-shadow: 0 8px 15px rgba(13,110,253,0.3); }
        .panel { display: none; }
        .panel.active { display: block; }
        .alert-sm { border-radius: 10px; padding: 10px 14px; font-size: 0.85rem; font-weight: 500; margin-bottom: 16px; }
        .sw { text-align: center; margin-top: 14px; font-size: 0.85rem; color: #64748b; }
        .sw a { color: #0d6efd; font-weight: 600; text-decoration: none; }
        .sw a:hover { text-decoration: underline; }
    </style>
</head>
<body>
    <div class="shape shape-1"></div>
    <div class="shape shape-2"></div>
    <div class="shape shape-3"></div>

    <div class="login-card">
        <div class="login-icon">
            <img src="/logo.png" alt="VSMS" style="width:56px;height:56px;object-fit:cover;border-radius:50%;">
        </div>
        <h3 class="text-center fw-bold mb-1">Welcome to VSMS</h3>
        <p class="text-center text-muted mb-4" style="font-size:0.9rem;">Sign in or create a new account</p>

        <div class="tab-switcher">
            <button class="tab-btn @loginActive" onclick="switchTab('login')" id="tab-login">
                <i class="fa-solid fa-right-to-bracket me-1"></i> Sign In
            </button>
            <button class="tab-btn @regActive" onclick="switchTab('register')" id="tab-reg">
                <i class="fa-solid fa-user-plus me-1"></i> Register
            </button>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger alert-sm"><i class="fa-solid fa-circle-exclamation me-2"></i>@ViewBag.Error</div>
        }
        @if (TempData["RegError"] != null)
        {
            <div class="alert alert-danger alert-sm"><i class="fa-solid fa-circle-exclamation me-2"></i>@TempData["RegError"]</div>
        }
        @if (TempData["RegSuccess"] != null)
        {
            <div class="alert alert-success alert-sm"><i class="fa-solid fa-circle-check me-2"></i>@TempData["RegSuccess"]</div>
        }

        <!-- LOGIN PANEL -->
        <div class="panel @loginActive" id="panel-login">
            <form method="post" action="/Auth/Login" autocomplete="off">
                <!-- Trick browser autofill -->
                <input type="text" style="display:none">
                <input type="password" style="display:none">
                <div class="input-wrap">
                    <i class="fa-regular fa-envelope"></i>
                    <input type="email" name="email" class="form-control" placeholder="Email Address" autocomplete="off" required>
                </div>
                <div class="input-wrap">
                    <i class="fa-solid fa-lock"></i>
                    <input type="password" name="password" class="form-control" placeholder="Password" autocomplete="new-password" required>
                </div>
                <button type="submit" class="btn btn-primary btn-submit">
                    <i class="fa-solid fa-right-to-bracket me-2"></i>Sign In
                </button>
            </form>
            <div class="sw">Don't have an account? <a href="#" onclick="switchTab('register'); return false;">Register here</a></div>
        </div>

        <!-- REGISTER PANEL -->
        <div class="panel @regActive" id="panel-reg">
            <form method="post" action="/Auth/Register" autocomplete="off">
                <div class="input-wrap">
                    <i class="fa-solid fa-user"></i>
                    <input type="text" name="Name" class="form-control" placeholder="Full Name" autocomplete="off" required>
                </div>
                <div class="input-wrap">
                    <i class="fa-regular fa-envelope"></i>
                    <input type="email" name="Email" class="form-control" placeholder="Email Address" autocomplete="off" required>
                </div>
                <div class="input-wrap">
                    <i class="fa-solid fa-phone"></i>
                    <input type="text" name="Contact" class="form-control" placeholder="Contact Number" autocomplete="off" required>
                </div>
                <div class="input-wrap">
                    <i class="fa-solid fa-lock"></i>
                    <input type="password" name="Pass" class="form-control" placeholder="Password" autocomplete="new-password" required>
                </div>
                <button type="submit" class="btn btn-primary btn-submit">
                    <i class="fa-solid fa-user-plus me-2"></i>Create Account
                </button>
            </form>
            <div class="sw">Already have an account? <a href="#" onclick="switchTab('login'); return false;">Sign in</a></div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function switchTab(t) {
            document.getElementById('tab-login').classList.toggle('active', t === 'login');
            document.getElementById('tab-reg').classList.toggle('active', t === 'register');
            document.getElementById('panel-login').classList.toggle('active', t === 'login');
            document.getElementById('panel-reg').classList.toggle('active', t === 'register');
        }

        // Validation helper
        function showErr(input, msg) {
            input.style.borderColor = '#dc2626';
            input.style.boxShadow = '0 0 0 3px rgba(220,38,38,0.12)';
            let err = input.parentElement.querySelector('.v-err');
            if (!err) { err = document.createElement('small'); err.className = 'v-err text-danger fw-medium mt-1 d-block'; input.parentElement.appendChild(err); }
            err.textContent = msg;
        }
        function clearErr(input) {
            input.style.borderColor = '';
            input.style.boxShadow = '';
            const err = input.parentElement.querySelector('.v-err');
            if (err) err.remove();
        }

        // Login form validation
        document.querySelector('#panel-login form').addEventListener('submit', function(e) {
            let ok = true;
            const email = this.querySelector('[name=email]');
            const pass  = this.querySelector('[name=password]');
            clearErr(email); clearErr(pass);
            if (!email.value.trim()) { showErr(email, 'Email is required.'); ok = false; }
            else if (!/^[^@]+@[^@]+\.[^@]+$/.test(email.value)) { showErr(email, 'Enter a valid email address.'); ok = false; }
            if (!pass.value.trim()) { showErr(pass, 'Password is required.'); ok = false; }
            else if (pass.value.length < 4) { showErr(pass, 'Password must be at least 4 characters.'); ok = false; }
            if (!ok) e.preventDefault();
        });

        // Register form validation
        document.querySelector('#panel-reg form').addEventListener('submit', function(e) {
            let ok = true;
            const name    = this.querySelector('[name=Name]');
            const email   = this.querySelector('[name=Email]');
            const contact = this.querySelector('[name=Contact]');
            const pass    = this.querySelector('[name=Pass]');
            [name, email, contact, pass].forEach(clearErr);
            if (!name.value.trim()) { showErr(name, 'Full name is required.'); ok = false; }
            else if (name.value.trim().length < 2) { showErr(name, 'Name must be at least 2 characters.'); ok = false; }
            if (!email.value.trim()) { showErr(email, 'Email is required.'); ok = false; }
            else if (!/^[^@]+@[^@]+\.[^@]+$/.test(email.value)) { showErr(email, 'Enter a valid email address.'); ok = false; }
            if (!contact.value.trim()) { showErr(contact, 'Contact number is required.'); ok = false; }
            else if (!/^\d{7,15}$/.test(contact.value.trim())) { showErr(contact, 'Enter a valid contact number (7-15 digits).'); ok = false; }
            if (!pass.value.trim()) { showErr(pass, 'Password is required.'); ok = false; }
            else if (pass.value.length < 4) { showErr(pass, 'Password must be at least 4 characters.'); ok = false; }
            if (!ok) e.preventDefault();
        });

        // Clear error on input
        document.querySelectorAll('.form-control').forEach(inp => {
            inp.addEventListener('input', () => clearErr(inp));
        });
    </script>
</body>
</html>
