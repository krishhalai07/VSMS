@{
    ViewData["Title"] = "Vehicles";
    Layout = "~/Views/Admin/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-5">
    <div>
        <h1 class="page-header mb-1">Vehicle Assets</h1>
        <p class="text-muted"><i class="fa-solid fa-car-side me-2 text-primary"></i>Manage database of registered mechanical assets</p>
    </div>
    <button type="button" class="btn-animated" data-bs-toggle="modal" data-bs-target="#addVehicleModal">
        <i class="fa-solid fa-car me-2"></i> Log New Vehicle
    </button>
</div>

<div class="card-clean mb-5 p-0">
    <div class="d-flex justify-content-between align-items-center p-4 border-bottom border-light">
        <div class="search-bar d-flex align-items-center bg-light border" style="width: 350px;">
            <i class="fa-solid fa-search text-muted me-2"></i>
            <input type="text" placeholder="Search plates or models..." class="bg-transparent border-0 w-100 outline-none">
        </div>
    </div>

    <div class="table-responsive p-0" style="overflow-x: visible;">
        <table class="table table-hover table-custom mb-0 align-middle">
            <thead class="bg-light text-muted text-uppercase fw-bold" style="font-size: 0.8rem; letter-spacing: 0.5px;">
                <tr>
                    <th class="ps-5 py-3 border-0">License Plate</th>
                    <th class="py-3 border-0">Manufacturer & Model</th>
                    <th class="py-3 border-0">Owner</th>
                    <th class="py-3 border-0">Year</th>
                    <th class="py-3 border-0">Last Service</th>
                    <th class="py-3 border-0">Status</th>
                    <th class="text-center pe-5 py-3 border-0">Actions</th>
                </tr>
            </thead>
            <tbody>
                <!-- Vehicle 1 -->
                <tr class="border-bottom text-dark">
                    <td class="ps-5 py-4 fw-bold text-primary font-monospace fs-5">ABC-1234</td>
                    <td>
                        <div class="d-flex align-items-center fw-bold">
                            <div class="p-2 bg-primary bg-opacity-10 text-primary rounded shadow-sm me-3 border border-primary border-opacity-25">
                                <i class="fa-solid fa-car-side"></i>
                            </div>
                            Toyota Camry
                        </div>
                    </td>
                    <td class="fw-medium text-dark"><i class="fa-regular fa-user me-2 text-muted"></i>John Doe</td>
                    <td class="text-muted fw-bold">2019</td>
                    <td class="text-muted fw-medium">12 Oct, 2023</td>
                    <td>
                        <div class="dropdown">
                            <button class="btn btn-sm fw-bold border-0 shadow-sm bg-success bg-opacity-10 text-success dropdown-toggle d-flex justify-content-between align-items-center" type="button" data-bs-toggle="dropdown" aria-expanded="false" style="width: 130px; border-radius: 8px;">
                                Approved
                            </button>
                            <ul class="dropdown-menu shadow-lg border-0 p-2 bg-white" style="border-radius: 12px; min-width: 130px; z-index: 1050;">
                                <li><a class="dropdown-item fw-bold text-success rounded bg-success bg-opacity-10 mb-1" href="#" onclick="updateVehicleStatus(event, this, 'Approved', 'success')">Approved</a></li>
                                <li><a class="dropdown-item fw-bold text-danger rounded transition-hover" href="#" onclick="updateVehicleStatus(event, this, 'Declined', 'danger')">Declined</a></li>
                            </ul>
                        </div>
                    </td>
                    <td class="text-center pe-5">
                        <button class="btn btn-sm btn-light text-secondary rounded-circle shadow-sm me-2 hover-elevate" title="Send Email" style="width: 38px; height: 38px;" onclick="showToast('Email draft opened for John Doe', 'primary')"><i class="fa-solid fa-envelope"></i></button>
                        <button class="btn btn-sm btn-light text-primary rounded-circle shadow-sm me-2 hover-elevate" data-bs-toggle="modal" data-bs-target="#addVehicleModal" title="Edit Vehicle" style="width: 38px; height: 38px;"><i class="fa-solid fa-pen"></i></button>
                        <button class="btn btn-sm btn-light text-danger rounded-circle shadow-sm hover-elevate" data-bs-toggle="modal" data-bs-target="#deleteConfirmationModal" title="Delete Vehicle" style="width: 38px; height: 38px;"><i class="fa-solid fa-trash"></i></button>
                    </td>
                </tr>
                
                <!-- Vehicle 2 -->
                <tr class="border-bottom text-dark">
                    <td class="ps-5 py-4 fw-bold text-primary font-monospace fs-5">XYZ-9876</td>
                    <td>
                        <div class="d-flex align-items-center fw-bold">
                            <div class="p-2 bg-success bg-opacity-10 text-success rounded shadow-sm me-3 border border-success border-opacity-25">
                                <i class="fa-solid fa-car-side"></i>
                            </div>
                            Honda Civic
                        </div>
                    </td>
                    <td class="fw-medium text-dark"><i class="fa-regular fa-user me-2 text-muted"></i>Jane Smith</td>
                    <td class="text-muted fw-bold">2021</td>
                    <td class="text-muted fw-medium">05 Nov, 2023</td>
                    <td>
                        <div class="dropdown">
                            <button class="btn btn-sm fw-bold border-0 shadow-sm bg-success bg-opacity-10 text-success dropdown-toggle d-flex justify-content-between align-items-center" type="button" data-bs-toggle="dropdown" aria-expanded="false" style="width: 130px; border-radius: 8px;">
                                Approved
                            </button>
                            <ul class="dropdown-menu shadow-lg border-0 p-2 bg-white" style="border-radius: 12px; min-width: 130px; z-index: 1050;">
                                <li><a class="dropdown-item fw-bold text-success rounded bg-success bg-opacity-10 mb-1" href="#" onclick="updateVehicleStatus(event, this, 'Approved', 'success')">Approved</a></li>
                                <li><a class="dropdown-item fw-bold text-danger rounded transition-hover" href="#" onclick="updateVehicleStatus(event, this, 'Declined', 'danger')">Declined</a></li>
                            </ul>
                        </div>
                    </td>
                    <td class="text-center pe-5">
                        <button class="btn btn-sm btn-light text-secondary rounded-circle shadow-sm me-2 hover-elevate" title="Send Email" style="width: 38px; height: 38px;" onclick="showToast('Email draft opened for Jane Smith', 'primary')"><i class="fa-solid fa-envelope"></i></button>
                        <button class="btn btn-sm btn-light text-primary rounded-circle shadow-sm me-2 hover-elevate" data-bs-toggle="modal" data-bs-target="#addVehicleModal" title="Edit Vehicle" style="width: 38px; height: 38px;"><i class="fa-solid fa-pen"></i></button>
                        <button class="btn btn-sm btn-light text-danger rounded-circle shadow-sm hover-elevate" data-bs-toggle="modal" data-bs-target="#deleteConfirmationModal" title="Delete Vehicle" style="width: 38px; height: 38px;"><i class="fa-solid fa-trash"></i></button>
                    </td>
                </tr>

                <!-- Vehicle 3 -->
                <tr class="border-bottom text-dark">
                    <td class="ps-5 py-4 fw-bold text-primary font-monospace fs-5">F150-TRK</td>
                    <td>
                        <div class="d-flex align-items-center fw-bold">
                            <div class="p-2 bg-warning bg-opacity-10 text-warning rounded shadow-sm me-3 border border-warning border-opacity-25">
                                <i class="fa-solid fa-truck-pickup"></i>
                            </div>
                            Ford F-150
                        </div>
                    </td>
                    <td class="fw-medium text-dark"><i class="fa-regular fa-user me-2 text-muted"></i>Robert Johnson</td>
                    <td class="text-muted fw-bold">2018</td>
                    <td class="text-muted fw-medium">22 Dec, 2023</td>
                    <td>
                        <div class="dropdown">
                            <button class="btn btn-sm fw-bold border-0 shadow-sm bg-danger bg-opacity-10 text-danger dropdown-toggle d-flex justify-content-between align-items-center" type="button" data-bs-toggle="dropdown" aria-expanded="false" style="width: 130px; border-radius: 8px;">
                                Declined
                            </button>
                            <ul class="dropdown-menu shadow-lg border-0 p-2 bg-white" style="border-radius: 12px; min-width: 130px; z-index: 1050;">
                                <li><a class="dropdown-item fw-bold text-success rounded transition-hover mb-1" href="#" onclick="updateVehicleStatus(event, this, 'Approved', 'success')">Approved</a></li>
                                <li><a class="dropdown-item fw-bold text-danger rounded bg-danger bg-opacity-10" href="#" onclick="updateVehicleStatus(event, this, 'Declined', 'danger')">Declined</a></li>
                            </ul>
                        </div>
                    </td>
                    <td class="text-center pe-5">
                        <button class="btn btn-sm btn-light text-secondary rounded-circle shadow-sm me-2 hover-elevate" title="Send Email" style="width: 38px; height: 38px;" onclick="showToast('Email draft opened for Robert Johnson', 'primary')"><i class="fa-solid fa-envelope"></i></button>
                        <button class="btn btn-sm btn-light text-primary rounded-circle shadow-sm me-2 hover-elevate" data-bs-toggle="modal" data-bs-target="#addVehicleModal" title="Edit Vehicle" style="width: 38px; height: 38px;"><i class="fa-solid fa-pen"></i></button>
                        <button class="btn btn-sm btn-light text-danger rounded-circle shadow-sm hover-elevate" data-bs-toggle="modal" data-bs-target="#deleteConfirmationModal" title="Delete Vehicle" style="width: 38px; height: 38px;"><i class="fa-solid fa-trash"></i></button>
                    </td>
                </tr>

                <!-- Vehicle 4 -->
                <tr class="border-bottom text-dark">
                    <td class="ps-5 py-4 fw-bold text-primary font-monospace fs-5">TSL-M3EV</td>
                    <td>
                        <div class="d-flex align-items-center fw-bold">
                            <div class="p-2 bg-info bg-opacity-10 text-info rounded shadow-sm me-3 border border-info border-opacity-25">
                                <i class="fa-solid fa-bolt"></i>
                            </div>
                            Tesla Model 3
                        </div>
                    </td>
                    <td class="fw-medium text-dark"><i class="fa-regular fa-user me-2 text-muted"></i>Emily Davis</td>
                    <td class="text-muted fw-bold">2023</td>
                    <td class="text-muted fw-medium">10 Jan, 2024</td>
                    <td>
                        <div class="dropdown">
                            <button class="btn btn-sm fw-bold border-0 shadow-sm bg-success bg-opacity-10 text-success dropdown-toggle d-flex justify-content-between align-items-center" type="button" data-bs-toggle="dropdown" aria-expanded="false" style="width: 130px; border-radius: 8px;">
                                Approved
                            </button>
                            <ul class="dropdown-menu shadow-lg border-0 p-2 bg-white" style="border-radius: 12px; min-width: 130px; z-index: 1050;">
                                <li><a class="dropdown-item fw-bold text-success rounded bg-success bg-opacity-10 mb-1" href="#" onclick="updateVehicleStatus(event, this, 'Approved', 'success')">Approved</a></li>
                                <li><a class="dropdown-item fw-bold text-danger rounded transition-hover" href="#" onclick="updateVehicleStatus(event, this, 'Declined', 'danger')">Declined</a></li>
                            </ul>
                        </div>
                    </td>
                    <td class="text-center pe-5">
                        <button class="btn btn-sm btn-light text-secondary rounded-circle shadow-sm me-2 hover-elevate" title="Send Email" style="width: 38px; height: 38px;" onclick="showToast('Email draft opened for Emily Davis', 'primary')"><i class="fa-solid fa-envelope"></i></button>
                        <button class="btn btn-sm btn-light text-primary rounded-circle shadow-sm me-2 hover-elevate" title="Edit Vehicle" style="width: 38px; height: 38px;" data-bs-toggle="modal" data-bs-target="#addVehicleModal"><i class="fa-solid fa-pen"></i></button>
                        <button class="btn btn-sm btn-light text-danger rounded-circle shadow-sm hover-elevate" title="Delete Vehicle" style="width: 38px; height: 38px;" data-bs-toggle="modal" data-bs-target="#deleteConfirmationModal"><i class="fa-solid fa-trash"></i></button>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<!-- Forms Animated Modal -->
<div class="modal fade" id="addVehicleModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0">
            <div class="modal-header">
                <h5 class="modal-title d-flex align-items-center fs-4">
                    <div class="bg-primary bg-opacity-10 text-primary rounded p-2 me-3">
                        <i class="fa-solid fa-car-burst"></i>
                    </div>
                    Log Vehicle
                </h5>
                <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            
            <div class="modal-body p-4 pt-4">
                <form>
                    <div class="row g-4">
                        <div class="col-12" style="animation: slideUpFade 0.4s both 0.1s;">
                            <div>
                                <label for="licensePlate" class="custom-label"><i class="fa-solid fa-barcode"></i>License Plate</label>
                                <input type="text" class="form-control text-uppercase font-monospace fw-bold text-primary" id="licensePlate" placeholder="XXX-0000" style="letter-spacing:1px;" required>
                            </div>
                        </div>
                        <div class="col-md-6" style="animation: slideUpFade 0.4s both 0.2s;">
                            <div>
                                <label for="manufacturer" class="custom-label"><i class="fa-solid fa-industry"></i>Manufacturer</label>
                                <select class="form-select fw-bold text-dark" id="manufacturer" required>
                                    <option value="" selected disabled>Select Make...</option>
                                    <option value="Toyota">Toyota</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-6" style="animation: slideUpFade 0.4s both 0.3s;">
                            <div>
                                <label for="model" class="custom-label"><i class="fa-solid fa-car-rear"></i>Model</label>
                                <input type="text" class="form-control" id="model" placeholder="Model name" required>
                            </div>
                        </div>
                        <div class="col-md-6" style="animation: slideUpFade 0.4s both 0.4s;">
                            <div>
                                <label for="year" class="custom-label"><i class="fa-regular fa-calendar-days"></i>Year</label>
                                <input type="number" class="form-control" id="year" placeholder="2023" min="1990" max="2025" required>
                            </div>
                        </div>
                        <div class="col-md-6" style="animation: slideUpFade 0.4s both 0.5s;">
                            <div>
                                <label for="clientLink" class="custom-label"><i class="fa-regular fa-user"></i>Owner Client</label>
                                <select class="form-select fw-medium text-dark" id="clientLink" required>
                                    <option value="" selected disabled>Select Owner...</option>
                                    <option value="1">John Doe (CST-001)</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer border-0 pb-4 pt-2">
                <button type="button" class="btn btn-light rounded-pill px-4 fw-bold me-2" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-animated rounded-pill px-5"><i class="fa-solid fa-check me-2"></i> Save Asset</button>
            </div>
        </div>
    </div>
</div>

<style>
    .hover-elevate:hover { transform: translateY(-3px); box-shadow: 0 4px 10px rgba(0,0,0,0.1) !important; background: white !important;}
    .table-hover tbody tr:hover { background-color: #f8fafc; box-shadow: 0 4px 10px rgba(0,0,0,0.02); transition: all 0.2s; }
</style>

@section Scripts {
    <script>
        function updateVehicleStatus(e, element, status, colorClass) {
            e.preventDefault();
            const btn = element.closest('.dropdown').querySelector('.dropdown-toggle');
            const menuItems = element.closest('.dropdown-menu').querySelectorAll('.dropdown-item');
            
            // reset menu item styling
            menuItems.forEach(item => {
                item.className = item.className.replace(/bg-[a-z]+ bg-opacity-10/g, 'transition-hover');
            });

            // Set button classes and text
            btn.className = `btn btn-sm fw-bold border-0 shadow-sm bg-${colorClass} bg-opacity-10 text-${colorClass} dropdown-toggle d-flex justify-content-between align-items-center`;
            btn.innerText = status;
            
            // Highlight selected option
            element.className = element.className.replace('transition-hover', `bg-${colorClass} bg-opacity-10`);
            
            if (typeof showToast === 'function') {
                showToast(`Vehicle status changed to ${status}`, colorClass === 'danger' ? 'danger' : 'success');
            }
        }
    </script>
}
