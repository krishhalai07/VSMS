@{
    ViewData["Title"] = "Service Management";
    Layout = "~/Views/Admin/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-5">
    <div>
        <h1 class="page-header mb-1">Service Modules</h1>
        <p class="text-muted"><i class="fa-solid fa-gears me-2 text-primary"></i>Configure workshop operations and pricing catalogs</p>
    </div>
    <button type="button" class="btn-animated" data-bs-toggle="modal" data-bs-target="#addServiceModal">
        <i class="fa-solid fa-square-plus me-2"></i> Deploy Module
    </button>
</div>

<div class="row g-4 mb-5">
    <!-- Service Option Cards -->
    <!-- Service Option 1 -->
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card-clean position-relative overflow-hidden h-100 p-0" style="border-top: 4px solid var(--primary);">
            <div class="p-4 d-flex justify-content-between align-items-start border-bottom border-light bg-light bg-opacity-50">
                <div>
                    <h5 class="fw-bold text-dark mb-1">Standard Maintenance</h5>
                    <p class="text-primary fw-bold letter-spacing-1 text-sm mb-0">SRV-BSK-01</p>
                </div>
                <h3 class="fw-bolder text-dark mb-0">$85.00</h3>
            </div>
            <div class="p-4 bg-white">
                <p class="text-muted text-sm mb-4">Core operational check: Oil exchange, filter replacement, fluid flush, and basic tire rotation.</p>
                
                <h6 class="text-dark text-uppercase letter-spacing-1 text-sm fw-bold mb-4"><i class="fa-solid fa-stopwatch text-warning me-2"></i>Estimated Cycle: 2.0 Hrs</h6>
                
                <div class="d-flex justify-content-between">
                    <button class="btn btn-sm btn-light text-primary rounded-pill px-4 fw-bold hover-elevate shadow-sm" data-bs-toggle="modal" data-bs-target="#addServiceModal"><i class="fa-solid fa-pen me-2"></i>Edit</button>
                    <button class="btn btn-sm btn-light text-danger rounded-circle shadow-sm hover-elevate" style="width: 32px; height: 32px;" data-bs-toggle="modal" data-bs-target="#deleteConfirmationModal"><i class="fa-solid fa-trash"></i></button>
                </div>
            </div>
        </div>
    </div>

    <!-- Service Option 2 -->
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card-clean position-relative overflow-hidden h-100 p-0" style="border-top: 4px solid var(--success);">
            <div class="p-4 d-flex justify-content-between align-items-start border-bottom border-light bg-light bg-opacity-50">
                <div>
                    <h5 class="fw-bold text-dark mb-1">Brake Pad Swap</h5>
                    <p class="text-success fw-bold letter-spacing-1 text-sm mb-0">SRV-BRK-02</p>
                </div>
                <h3 class="fw-bolder text-dark mb-0">$250.00</h3>
            </div>
            <div class="p-4 bg-white">
                <p class="text-muted text-sm mb-4">Complete replacement of front and rear brake pads, rotor resurfacing (if needed), and fluid top-off.</p>
                
                <h6 class="text-dark text-uppercase letter-spacing-1 text-sm fw-bold mb-4"><i class="fa-solid fa-stopwatch text-warning me-2"></i>Estimated Cycle: 3.5 Hrs</h6>
                
                <div class="d-flex justify-content-between">
                    <button class="btn btn-sm btn-light text-primary rounded-pill px-4 fw-bold hover-elevate shadow-sm" data-bs-toggle="modal" data-bs-target="#addServiceModal"><i class="fa-solid fa-pen me-2"></i>Edit</button>
                    <button class="btn btn-sm btn-light text-danger rounded-circle shadow-sm hover-elevate" style="width: 32px; height: 32px;" data-bs-toggle="modal" data-bs-target="#deleteConfirmationModal"><i class="fa-solid fa-trash"></i></button>
                </div>
            </div>
        </div>
    </div>

    <!-- Service Option 3 -->
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card-clean position-relative overflow-hidden h-100 p-0" style="border-top: 4px solid var(--secondary);">
            <div class="p-4 d-flex justify-content-between align-items-start border-bottom border-light bg-light bg-opacity-50">
                <div>
                    <h5 class="fw-bold text-dark mb-1">Diagnostics Scan</h5>
                    <p class="text-secondary fw-bold letter-spacing-1 text-sm mb-0">SRV-TRN-03</p>
                </div>
                <h3 class="fw-bolder text-dark mb-0">$150.00</h3>
            </div>
            <div class="p-4 bg-white">
                <p class="text-muted text-sm mb-4">Complete OBD2 electronic scans, sensor recalibration, and thorough electrical safety analysis.</p>
                
                <h6 class="text-dark text-uppercase letter-spacing-1 text-sm fw-bold mb-4"><i class="fa-solid fa-stopwatch text-warning me-2"></i>Estimated Cycle: 1.5 Hrs</h6>
                
                <div class="d-flex justify-content-between">
                    <button class="btn btn-sm btn-light text-primary rounded-pill px-4 fw-bold hover-elevate shadow-sm" data-bs-toggle="modal" data-bs-target="#addServiceModal"><i class="fa-solid fa-pen me-2"></i>Edit</button>
                    <button class="btn btn-sm btn-light text-danger rounded-circle shadow-sm hover-elevate" style="width: 32px; height: 32px;" data-bs-toggle="modal" data-bs-target="#deleteConfirmationModal"><i class="fa-solid fa-trash"></i></button>
                </div>
            </div>
        </div>
    </div>

    <!-- Service Option 4 -->
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card-clean position-relative overflow-hidden h-100 p-0" style="border-top: 4px solid #f59e0b;">
            <div class="p-4 d-flex justify-content-between align-items-start border-bottom border-light bg-light bg-opacity-50">
                <div>
                    <h5 class="fw-bold text-dark mb-1">AC Depressurizing</h5>
                    <p class="text-warning fw-bold letter-spacing-1 text-sm mb-0" style="color: #d97706 !important;">SRV-ACS-04</p>
                </div>
                <h3 class="fw-bolder text-dark mb-0">$120.00</h3>
            </div>
            <div class="p-4 bg-white">
                <p class="text-muted text-sm mb-4">Freon flush, line depressurization, cabin filter replacement, and climate control test run.</p>
                
                <h6 class="text-dark text-uppercase letter-spacing-1 text-sm fw-bold mb-4"><i class="fa-solid fa-stopwatch text-warning me-2"></i>Estimated Cycle: 1.0 Hrs</h6>
                
                <div class="d-flex justify-content-between">
                    <button class="btn btn-sm btn-light text-primary rounded-pill px-4 fw-bold hover-elevate shadow-sm" data-bs-toggle="modal" data-bs-target="#addServiceModal"><i class="fa-solid fa-pen me-2"></i>Edit</button>
                    <button class="btn btn-sm btn-light text-danger rounded-circle shadow-sm hover-elevate" style="width: 32px; height: 32px;" data-bs-toggle="modal" data-bs-target="#deleteConfirmationModal"><i class="fa-solid fa-trash"></i></button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="addServiceModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0">
            <div class="modal-header d-flex flex-column align-items-start border-0 pb-0">
                <h5 class="modal-title text-dark fw-bold fs-4 d-flex align-items-center">
                    <div class="bg-primary bg-opacity-10 text-primary rounded p-2 me-3">
                        <i class="fa-solid fa-gears"></i>
                    </div>
                    Deploy Module
                </h5>
                <button type="button" class="btn-close position-absolute shadow-none" style="top:25px; right: 25px;" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            
            <div class="modal-body p-4 pt-4">
                <form>
                    <div class="row g-4">
                        <div class="col-12" style="animation: slideUpFade 0.4s both 0.1s;">
                            <div>
                                <label for="modDesignation" class="custom-label"><i class="fa-solid fa-tag"></i>Module Designation</label>
                                <input type="text" class="form-control fw-bold text-dark" id="modDesignation" placeholder="e.g. Transmission Repair" required>
                            </div>
                        </div>
                        <div class="col-12" style="animation: slideUpFade 0.4s both 0.2s;">
                            <div>
                                <label for="modDesc" class="custom-label"><i class="fa-solid fa-align-left"></i>Service Description</label>
                                <textarea class="form-control" id="modDesc" placeholder="Describe the process..." style="height: 80px;" required></textarea>
                            </div>
                        </div>
                        <div class="col-md-6" style="animation: slideUpFade 0.4s both 0.3s;">
                            <div>
                                <label for="modCost" class="custom-label"><i class="fa-solid fa-dollar-sign"></i>Base Cost ($)</label>
                                <input type="number" step="0.01" class="form-control text-primary fs-5 fw-bold" id="modCost" placeholder="0.00" required>
                            </div>
                        </div>
                        <div class="col-md-6" style="animation: slideUpFade 0.4s both 0.4s;">
                            <div>
                                <label for="modTime" class="custom-label"><i class="fa-regular fa-clock"></i>Est Time (Hrs)</label>
                                <input type="number" step="0.5" class="form-control fw-bold" id="modTime" placeholder="2.5" required>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer pb-4 pt-2 border-0 justify-content-center">
                <button type="button" class="btn btn-light rounded-pill px-4 fw-bold me-2" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-animated rounded-pill px-5"><i class="fa-solid fa-check me-2"></i> Save Module</button>
            </div>
        </div>
    </div>
</div>

<style>
    .letter-spacing-1 { letter-spacing: 1px; }
    .text-sm { font-size: 0.875rem; }
    .hover-elevate:hover { transform: translateY(-3px); box-shadow: 0 4px 10px rgba(0,0,0,0.1) !important;}
</style>
