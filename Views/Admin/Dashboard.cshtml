@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Admin/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-5">
    <div>
        <h1 class="page-header">Dashboard Overview</h1>
        <p class="text-muted mt-1"><i class="fa-solid fa-chart-line me-2 text-primary"></i>Live metrics and workshop capacity</p>
    </div>
    <button class="btn-animated"><i class="fa-solid fa-download me-2"></i> Export Report</button>
</div>

<div class="row g-4 mb-5">
    <div class="col-12 col-md-6 col-xl-3">
        <div class="card-clean h-100 p-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div class="p-3 rounded-circle bg-primary bg-opacity-10 text-primary">
                    <i class="fa-solid fa-users fs-4"></i>
                </div>
                <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 rounded-pill px-3 py-1 fw-bold">+12%</span>
            </div>
            <h5 class="text-muted fw-bold mb-1">Total Customers</h5>
            <h2 class="fw-bolder mb-0 text-dark" style="font-size: 2.5rem; letter-spacing: -1px;">4</h2>
        </div>
    </div>

    <div class="col-12 col-md-6 col-xl-3">
        <div class="card-clean h-100 p-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div class="p-3 rounded-circle bg-warning bg-opacity-10 text-warning">
                    <i class="fa-solid fa-wrench fs-4"></i>
                </div>
                <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 rounded-pill px-3 py-1 fw-bold">HIGH</span>
            </div>
            <h5 class="text-muted fw-bold mb-1">Active Jobs</h5>
            <h2 class="fw-bolder mb-0 text-dark" style="font-size: 2.5rem; letter-spacing: -1px;">3</h2>
            <div class="progress mt-3" style="height: 6px;">
                <div class="progress-bar progress-bar-animated progress-bar-striped bg-warning" style="width: 75%;"></div>
            </div>
        </div>
    </div>

    <div class="col-12 col-md-6 col-xl-3">
        <div class="card-clean h-100 p-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div class="p-3 rounded-circle bg-info bg-opacity-10 text-info">
                    <i class="fa-solid fa-car-on fs-4"></i>
                </div>
                <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 rounded-pill px-3 py-1 fw-bold">+8%</span>
            </div>
            <h5 class="text-muted fw-bold mb-1">Vehicles Serviced</h5>
            <h2 class="fw-bolder mb-0 text-dark" style="font-size: 2.5rem; letter-spacing: -1px;">4</h2>
        </div>
    </div>

    <div class="col-12 col-md-6 col-xl-3">
        <div class="card-clean h-100 p-4 position-relative overflow-hidden" style="background: linear-gradient(135deg, var(--primary), #6366f1); color: white;">
            <i class="fa-solid fa-wallet position-absolute opacity-10" style="font-size: 8rem; right: -20px; bottom: -20px;"></i>
            <div class="position-relative z-1">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div class="p-3 rounded-circle bg-white bg-opacity-25 text-white">
                        <i class="fa-solid fa-sack-dollar fs-4"></i>
                    </div>
                </div>
                <h5 class="text-white-50 fw-bold mb-1">Total Revenue</h5>
                <h2 class="fw-bolder mb-0 text-white" style="font-size: 2.5rem; letter-spacing: -1px;">$533.50</h2>
                <a href="#" class="text-white fw-bold text-decoration-none mt-3 d-inline-block shadow-sm pb-1 border-bottom">View Financials <i class="fa-solid fa-arrow-right ms-1"></i></a>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-12 col-xl-8">
        <div class="card-clean h-100 p-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h4 class="fw-bold mb-0 text-dark">Performance Metrics</h4>
                <div class="btn-group bg-light p-1 rounded-pill border">
                    <button class="btn btn-sm btn-white text-dark rounded-pill fw-bold shadow-sm px-4">Weekly</button>
                    <button class="btn btn-sm text-muted rounded-pill fw-bold px-4 hover-lift">Monthly</button>
                </div>
            </div>
            <div style="height: 300px; width: 100%;">
                <canvas id="performanceChart"></canvas>
            </div>
        </div>
    </div>

    <div class="col-12 col-xl-4">
        <div class="card-clean h-100 p-4 d-flex flex-column">
            <h4 class="fw-bold mb-4 text-dark">Job Distribution</h4>
            <div class="mt-auto position-relative d-flex justify-content-center align-items-center mb-4" style="height: 220px;">
                <canvas id="statusChart"></canvas>
                <div class="position-absolute text-center bg-white rounded-circle shadow-sm d-flex flex-column justify-content-center" style="width: 100px; height: 100px;">
                    <h2 class="fw-bolder text-dark mb-0">3</h2>
                    <small class="text-muted fw-bold">Jobs</small>
                </div>
            </div>
            <div class="mt-auto mb-2">
                <div class="d-flex justify-content-between mb-2"><span class="fw-medium text-muted"><i class="fa-solid fa-circle text-warning me-2"></i>Pending</span><span class="fw-bold fs-5">1</span></div>
                <div class="d-flex justify-content-between mb-2"><span class="fw-medium text-muted"><i class="fa-solid fa-circle text-primary me-2"></i>In Progress</span><span class="fw-bold fs-5">1</span></div>
                <div class="d-flex justify-content-between"><span class="fw-medium text-muted"><i class="fa-solid fa-circle text-success me-2"></i>Completed</span><span class="fw-bold fs-5">1</span></div>
            </div>
        </div>
    </div>
</div>

<style>
    .hover-lift:hover { background: white; transform: translateY(-1px); box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); }
</style>

@section Scripts {
    <script>
        Chart.defaults.color = '#64748b';
        Chart.defaults.font.family = 'Inter';
        
        const ctxPerf = document.getElementById('performanceChart').getContext('2d');
        
        let gradientLight = ctxPerf.createLinearGradient(0, 0, 0, 300);
        gradientLight.addColorStop(0, 'rgba(67, 56, 202, 0.2)');
        gradientLight.addColorStop(1, 'rgba(67, 56, 202, 0.0)');

        new Chart(ctxPerf, {
            type: 'line',
            data: {
                labels: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'],
                datasets: [{
                    label: 'Efficiency',
                    data: [65, 78, 55, 92, 85, 110, 95],
                    backgroundColor: gradientLight,
                    borderColor: '#4338ca',
                    borderWidth: 3,
                    pointBackgroundColor: '#ffffff',
                    pointBorderColor: '#4338ca',
                    pointBorderWidth: 2,
                    pointRadius: 6,
                    pointHoverRadius: 8,
                    fill: true,
                    tension: 0.4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                animation: {
                    x: { duration: 1000, easing: 'easeOutQuart' },
                    y: { duration: 1500, easing: 'easeOutBounce' }
                },
                plugins: { legend: { display: false } },
                scales: {
                    x: { grid: { display: false }, border: { display: false } },
                    y: { grid: { color: '#e2e8f0', borderDash: [5, 5] }, border: { display: false }, beginAtZero: true }
                }
            }
        });

        const ctxStatus = document.getElementById('statusChart').getContext('2d');
        new Chart(ctxStatus, {
            type: 'doughnut',
            data: {
                labels: ['Pending', 'In Progress', 'Completed'],
                datasets: [{
                    data: [1, 1, 1],
                    backgroundColor: ['#f59e0b', '#4338ca', '#10b981'],
                    borderWidth: 0,
                    hoverOffset: 10
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '75%',
                plugins: { legend: { display: false } },
                animation: { animateScale: true, animateRotate: true, duration: 1500 }
            }
        });
    </script>
}
