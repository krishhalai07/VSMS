@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Admin/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-5">
    <div>
        <h1 class="page-header">Dashboard Overview</h1>
        <p class="text-muted mt-1"><i class="fa-solid fa-chart-line me-2 text-primary"></i>Live metrics and workshop capacity</p>
    </div>
    <button class="btn-animated"><i class="fa-solid fa-download me-2"></i> Export Report</button>
</div>

<div class="row g-4 mb-5">
    <div class="col-12 col-md-6 col-xl-3">
        <div class="card-clean h-100 p-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div class="p-3 rounded-circle bg-primary bg-opacity-10 text-primary">
                    <i class="fa-solid fa-users fs-4"></i>
                </div>
            </div>
            <h5 class="text-muted fw-bold mb-1">Total Customers</h5>
            <h2 class="fw-bolder mb-0 text-dark" style="font-size: 2.5rem; letter-spacing: -1px;">4</h2>
        </div>
    </div>

    <div class="col-12 col-md-6 col-xl-3">
        <div class="card-clean h-100 p-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div class="p-3 rounded-circle bg-warning bg-opacity-10 text-warning">
                    <i class="fa-solid fa-wrench fs-4"></i>
                </div>
            </div>
            <h5 class="text-muted fw-bold mb-1">Available Mechanics</h5>
            <h2 class="fw-bolder mb-0 text-dark" style="font-size: 2.5rem; letter-spacing: -1px;">3</h2>
            <div class="progress mt-3" style="height: 6px;">
                <div class="progress-bar progress-bar-animated progress-bar-striped bg-warning" style="width: 75%;"></div>
            </div>
        </div>
    </div>

    <div class="col-12 col-md-6 col-xl-3">
        <div class="card-clean h-100 p-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div class="p-3 rounded-circle bg-info bg-opacity-10 text-info">
                    <i class="fa-solid fa-car-on fs-4"></i>
                </div>
            </div>
            <h5 class="text-muted fw-bold mb-1">Vehicles Serviced</h5>
            <h2 class="fw-bolder mb-0 text-dark" style="font-size: 2.5rem; letter-spacing: -1px;">4</h2>
        </div>
    </div>

    <div class="col-12 col-md-6 col-xl-3">
        <div class="card-clean h-100 p-4 position-relative overflow-hidden" style="background: linear-gradient(135deg, var(--primary), #6366f1); color: white;">
            <i class="fa-solid fa-wallet position-absolute opacity-10" style="font-size: 8rem; right: -20px; bottom: -20px;"></i>
            <div class="position-relative z-1">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div class="p-3 rounded-circle bg-white bg-opacity-25 text-white">
                        <i class="fa-solid fa-sack-dollar fs-4"></i>
                    </div>
                </div>
                <h5 class="text-white-50 fw-bold mb-1">Total Revenue</h5>
                <h2 class="fw-bolder mb-0 text-white" style="font-size: 2.5rem; letter-spacing: -1px;">$533.50</h2>
                <a href="#" class="text-white fw-bold text-decoration-none mt-3 d-inline-block shadow-sm pb-1 border-bottom">View Financials <i class="fa-solid fa-arrow-right ms-1"></i></a>
            </div>
        </div>
    </div>
</div>


<style>
    .hover-lift:hover { background: white; transform: translateY(-1px); box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); }
</style>

