@model List<VSMS.Models.Billing>
@{
    ViewData["Title"] = "Billing";
    Layout = "~/Views/Admin/_Layout.cshtml";
    var jobIds = ViewBag.JobIds as List<int> ?? new();
}

<div class="d-flex justify-content-between align-items-center mb-5">
    <div>
        <h1 class="page-header mb-1">Financial Ledgers</h1>
        <p class="text-muted"><i class="fa-solid fa-file-invoice-dollar me-2 text-primary"></i>Process invoices and payments</p>
    </div>
    <button type="button" class="btn-animated" data-bs-toggle="modal" data-bs-target="#createInvoiceModal">
        <i class="fa-solid fa-money-bill-transfer me-2"></i> Compile Invoice
    </button>
</div>

@if (TempData["Toast"] != null)
{
    <div class="alert alert-success rounded-3 py-2 mb-4"><i class="fa-solid fa-circle-check me-2"></i>@TempData["Toast"]</div>
}

<div class="card-clean mb-5 p-0">
    <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
            <thead class="bg-light text-muted text-uppercase fw-bold" style="font-size:0.8rem;letter-spacing:0.5px;">
                <tr>
                    <th class="ps-5 py-3 border-0">B_id</th>
                    <th class="py-3 border-0">J_id</th>
                    <th class="py-3 border-0">Part Cost</th>
                    <th class="py-3 border-0">GST</th>
                    <th class="py-3 border-0">Total Cost</th>
                    <th class="py-3 border-0">Status</th>
                    <th class="py-3 border-0">Payment Type</th>
                    <th class="text-center pe-5 py-3 border-0">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var b in Model)
                {
                    var sc = b.Status switch {
                        "Paid"    => "success",
                        "Overdue" => "danger",
                        _         => "warning"
                    };
                    <tr class="border-bottom text-dark">
                        <td class="ps-5 py-3 fw-bold text-primary font-monospace">#@b.B_id</td>
                        <td class="fw-bold font-monospace">@b.J_id</td>
                        <td class="text-muted font-monospace">@b.Part_cost</td>
                        <td class="text-muted font-monospace">@b.Gst</td>
                        <td class="fw-bolder text-dark fs-5 font-monospace">@b.Total_cost</td>
                        <td>
                            <span class="badge bg-@sc bg-opacity-10 text-@sc border border-@sc border-opacity-25 rounded-pill px-3 py-2 fw-bold">
                                @b.Status
                            </span>
                        </td>
                        <td class="text-muted fw-bold">@b.Payment_type</td>
                        <td class="text-center pe-5">
                            <form method="post" action="/Admin/DeleteBilling" class="d-inline"
                                  onsubmit="return confirm('Delete billing record #@b.B_id?')">
                                <input type="hidden" name="id" value="@b.B_id" />
                                <button class="btn btn-sm btn-light text-danger rounded-circle shadow-sm"
                                        style="width:38px;height:38px;" title="Delete">
                                    <i class="fa-solid fa-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="8" class="text-center text-muted py-5">No billing records found.</td></tr>
                }
            </tbody>
        </table>
    </div>
    <div class="p-4 border-top border-light">
        <span class="text-muted fw-medium">@Model.Count record(s)</span>
    </div>
</div>

<!-- Compile Invoice Modal -->
<div class="modal fade" id="createInvoiceModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0">
            <div class="modal-header">
                <h5 class="modal-title d-flex align-items-center fs-4">
                    <div class="bg-primary bg-opacity-10 text-primary rounded p-2 me-3">
                        <i class="fa-solid fa-file-invoice-dollar"></i>
                    </div>
                    Compile Invoice
                </h5>
                <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" action="/Admin/AddBilling" id="billingForm">
                <div class="modal-body p-4">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="custom-label"><i class="fa-solid fa-wrench"></i> Job Card (J_id)</label>
                            <select name="J_id" class="form-select fw-bold" required>
                                <option value="" disabled selected>Select job card...</option>
                                @foreach (var jid in jobIds)
                                {
                                    <option value="@jid">#@jid</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="custom-label"><i class="fa-solid fa-box"></i> Part Cost</label>
                            <input type="number" name="Part_cost" id="partCost" class="form-control fw-bold" placeholder="0" required oninput="calcTotal()">
                        </div>
                        <div class="col-md-6">
                            <label class="custom-label"><i class="fa-solid fa-percent"></i> GST</label>
                            <input type="number" name="Gst" id="gstVal" class="form-control fw-bold" placeholder="0" required oninput="calcTotal()">
                        </div>
                        <div class="col-12">
                            <label class="custom-label"><i class="fa-solid fa-calculator"></i> Total Cost</label>
                            <input type="number" name="Total_cost" id="totalCost"
                                   class="form-control fw-bold text-success fs-5 bg-success bg-opacity-10 border-success border-opacity-25"
                                   placeholder="0" required>
                        </div>
                        <div class="col-md-6">
                            <label class="custom-label"><i class="fa-solid fa-circle-half-stroke"></i> Status</label>
                            <select name="Status" class="form-select fw-bold">
                                <option value="Pending" selected>Pending</option>
                                <option value="Paid">Paid</option>
                                <option value="Overdue">Overdue</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="custom-label"><i class="fa-solid fa-credit-card"></i> Payment Type</label>
                            <select name="Payment_type" class="form-select fw-bold">
                                <option value="Cash">Cash</option>
                                <option value="Credit Card">Credit Card</option>
                                <option value="UPI">UPI</option>
                                <option value="Bank Transfer">Bank Transfer</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 pb-4">
                    <button type="button" class="btn btn-light rounded-pill px-4 fw-bold" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-animated rounded-pill px-5">
                        <i class="fa-solid fa-save me-2"></i> Save Invoice
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>.table-hover tbody tr:hover { background-color:#f8fafc; }</style>

@section Scripts {
    <script>
        function calcTotal() {
            const p = parseInt(document.getElementById('partCost').value) || 0;
            const g = parseInt(document.getElementById('gstVal').value) || 0;
            document.getElementById('totalCost').value = p + g;
        }
    </script>
}
