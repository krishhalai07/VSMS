@{
    ViewData["Title"] = "Billing";
    Layout = "~/Views/Admin/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-5">
    <div>
        <h1 class="page-header mb-1">Financial Ledgers</h1>
        <p class="text-muted"><i class="fa-solid fa-file-invoice-dollar me-2 text-primary"></i>Process invoices, payments, and digital receipts</p>
    </div>
    <button type="button" class="btn-animated" data-bs-toggle="modal" data-bs-target="#createInvoiceModal">
        <i class="fa-solid fa-money-bill-transfer me-2"></i> Compile Invoice
    </button>
</div>

<div class="card-clean mb-5 p-0">
    <div class="table-responsive p-0">
        <table class="table table-hover table-custom mb-0 align-middle">
            <thead class="bg-light text-muted text-uppercase fw-bold" style="font-size: 0.8rem; letter-spacing: 0.5px;">
                <tr>
                    <th class="ps-5 py-3 border-0">Invoice Hash</th>
                    <th class="py-3 border-0">Linked Node</th>
                    <th class="py-3 border-0">Date Issued</th>
                    <th class="py-3 border-0">Grand Total</th>
                    <th class="py-3 border-0">Condition</th>
                    <th class="text-center pe-5 py-3 border-0">Actions</th>
                </tr>
            </thead>
            <tbody>
                <!-- Invoice 1 -->
                <tr class="border-bottom text-dark">
                    <td class="ps-5 py-4 fw-bold text-dark font-monospace fs-5">#INV-99011</td>
                    <td>
                        <div class="d-flex flex-column">
                            <span class="mb-1 fw-bold text-dark">Emily Davis (<span class="text-primary font-monospace">JC-1003</span>)</span>
                            <span class="text-muted fw-bold"><i class="fa-solid fa-car-side me-2"></i>Diagnostics Scan</span>
                        </div>
                    </td>
                    <td class="text-muted fw-medium">15 Jan, 2024</td>
                    <td class="fw-bolder text-dark fs-5">$165.00</td>
                    <td><span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 rounded-pill px-3 py-2 fw-bold">PAID</span></td>
                    <td class="text-center pe-5">
                        <button class="btn btn-sm btn-light text-primary rounded-circle shadow-sm me-2 hover-elevate" style="width: 38px; height: 38px;" title="View PDF" onclick="showToast('Invoice PDF preview generated successfully', 'success')"><i class="fa-solid fa-file-pdf"></i></button>
                        <button class="btn btn-sm btn-light text-secondary rounded-circle shadow-sm hover-elevate" style="width: 38px; height: 38px;" title="Send via Email" onclick="showToast('Invoice successfully sent to client email', 'primary')"><i class="fa-solid fa-paper-plane"></i></button>
                    </td>
                </tr>

                <!-- Invoice 2 -->
                <tr class="border-bottom text-dark">
                    <td class="ps-5 py-4 fw-bold text-dark font-monospace fs-5">#INV-99012</td>
                    <td>
                        <div class="d-flex flex-column">
                            <span class="mb-1 fw-bold text-dark">John Doe (<span class="text-primary font-monospace">JC-1001</span>)</span>
                            <span class="text-muted fw-bold"><i class="fa-solid fa-car-side me-2"></i>Standard Maint.</span>
                        </div>
                    </td>
                    <td class="text-muted fw-medium">20 Jan, 2024</td>
                    <td class="fw-bolder text-dark fs-5">$93.50</td>
                    <td><span class="badge bg-warning bg-opacity-10 text-warning border border-warning border-opacity-25 rounded-pill px-3 py-2 fw-bold">PENDING</span></td>
                    <td class="text-center pe-5">
                        <button class="btn btn-sm btn-light text-primary rounded-circle shadow-sm me-2 hover-elevate" style="width: 38px; height: 38px;" title="View PDF" onclick="showToast('Invoice PDF preview generated successfully', 'success')"><i class="fa-solid fa-file-pdf"></i></button>
                        <button class="btn btn-sm btn-light text-secondary rounded-circle shadow-sm hover-elevate" style="width: 38px; height: 38px;" title="Send via Email" onclick="showToast('Invoice successfully sent to client email', 'primary')"><i class="fa-solid fa-paper-plane"></i></button>
                    </td>
                </tr>

                <!-- Invoice 3 -->
                <tr class="border-bottom text-dark">
                    <td class="ps-5 py-4 fw-bold text-dark font-monospace fs-5">#INV-99013</td>
                    <td>
                        <div class="d-flex flex-column">
                            <span class="mb-1 fw-bold text-dark">Jane Smith (<span class="text-primary font-monospace">JC-1002</span>)</span>
                            <span class="text-muted fw-bold"><i class="fa-solid fa-car-side me-2"></i>Brake Pad Swap</span>
                        </div>
                    </td>
                    <td class="text-muted fw-medium">05 Feb, 2024</td>
                    <td class="fw-bolder text-dark fs-5">$275.00</td>
                    <td><span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 rounded-pill px-3 py-2 fw-bold">OVERDUE</span></td>
                    <td class="text-center pe-5">
                        <button class="btn btn-sm btn-light text-primary rounded-circle shadow-sm me-2 hover-elevate" style="width: 38px; height: 38px;" title="View PDF" onclick="showToast('Invoice PDF preview generated successfully', 'success')"><i class="fa-solid fa-file-pdf"></i></button>
                        <button class="btn btn-sm btn-light text-secondary rounded-circle shadow-sm hover-elevate" style="width: 38px; height: 38px;" title="Send via Email" onclick="showToast('Invoice successfully sent to client email', 'primary')"><i class="fa-solid fa-paper-plane"></i></button>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="createInvoiceModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0">
            <div class="modal-header d-flex flex-column align-items-start border-0 pb-0 pt-4 px-5">
                <h5 class="modal-title text-dark fw-bold fs-3 letter-spacing-1 d-flex align-items-center">
                    <div class="bg-primary bg-opacity-10 text-primary rounded p-2 me-3 fs-4">
                        <i class="fa-solid fa-file-invoice-dollar"></i>
                    </div>
                    COMPILE INVOICE
                </h5>
                <button type="button" class="btn-close position-absolute shadow-none" style="top:25px; right: 25px;" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            
            <div class="modal-body p-5 pt-4">
                <form>
                    <div class="row g-4 mb-4 pb-4 border-bottom border-light">
                        <div class="col-md-6" style="animation: slideUpFade 0.4s both 0.1s;">
                            <div>
                                <label for="invRef" class="custom-label"><i class="fa-solid fa-link"></i>Job Card Reference</label>
                                <select class="form-select bg-light fw-bold text-dark" id="invRef" required>
                                    <option value="" selected disabled>Select Reference...</option>
                                    <option value="1">#JC-1001 (John Doe)</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-6" style="animation: slideUpFade 0.4s both 0.2s;">
                            <div>
                                <label for="invDate" class="custom-label"><i class="fa-solid fa-calendar-day"></i>Issuance Timestamp</label>
                                <input type="date" class="form-control" id="invDate" required>
                            </div>
                        </div>
                    </div>

                    <h6 class="text-dark fw-bold mb-3" style="animation: slideUpFade 0.4s both 0.3s;"><i class="fa-solid fa-calculator me-2 text-primary"></i>Ledger Computation</h6>
                    <div class="row g-3 mb-4" style="animation: slideUpFade 0.4s both 0.4s;">
                        <div class="col-md-5">
                            <div>
                                <label for="invSub1" class="custom-label"><i class="fa-solid fa-wrench"></i>Service Subtotal ($)</label>
                                <input type="number" class="form-control fw-bold" id="invSub1" placeholder="0.00" required>
                            </div>
                        </div>
                        <div class="col-md-5">
                            <div>
                                <label for="invSub2" class="custom-label"><i class="fa-solid fa-box"></i>Parts Subtotal ($)</label>
                                <input type="number" class="form-control fw-bold" id="invSub2" placeholder="0.00" required>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div>
                                <label for="invTax" class="custom-label"><i class="fa-solid fa-percent"></i>Tax Ratio</label>
                                <input type="number" class="form-control fw-bold" id="invTax" placeholder="10" required>
                            </div>
                        </div>
                    </div>

                    <div class="p-4 rounded-4 shadow-sm" style="background: linear-gradient(135deg, var(--primary), #6366f1); animation: slideUpFade 0.4s both 0.5s;">
                        <div class="d-flex justify-content-between align-items-center">
                            <h5 class="fw-bold text-white mb-0">TOTAL OUTSTANDING</h5>
                            <h2 class="fw-bolder text-white mb-0">$0.00</h2>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer pb-4 pt-1 border-0 justify-content-end px-5">
                <button type="button" class="btn btn-light rounded-pill px-4 fw-bold me-2" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-animated rounded-pill px-5"><i class="fa-solid fa-lock me-2"></i> Lock Invoice</button>
            </div>
        </div>
    </div>
</div>

<style>
    .letter-spacing-1 { letter-spacing: 1px; }
    .text-sm { font-size: 0.875rem; }
    .hover-elevate:hover { transform: translateY(-3px); box-shadow: 0 4px 10px rgba(0,0,0,0.1) !important;}
    .hover-lift:hover { background: white; transform: translateY(-1px); box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); }
    .table-hover tbody tr:hover { background-color: #f8fafc; transform: scale(1.005); box-shadow: 0 4px 10px rgba(0,0,0,0.02); transition: all 0.2s; }
</style>
