@model List<VSMS.Models.Billing>
@{
    ViewData["Title"] = "Billing";
    Layout = "~/Views/Admin/_Layout.cshtml";
    var jobIds = ViewBag.JobIds as List<int> ?? new();
}

<div class="d-flex justify-content-between align-items-center mb-5">
    <div>
        <h1 class="page-header mb-1">Financial Ledgers</h1>
        <p class="text-muted"><i class="fa-solid fa-file-invoice-dollar me-2 text-primary"></i>Process invoices and payments</p>
    </div>
    <button type="button" class="btn-animated" data-bs-toggle="modal" data-bs-target="#createInvoiceModal">
        <i class="fa-solid fa-money-bill-transfer me-2"></i> Compile Invoice
    </button>
</div>

@if (TempData["Toast"] != null)
{
    <div class="alert alert-success rounded-3 py-2 mb-4"><i class="fa-solid fa-circle-check me-2"></i>@TempData["Toast"]</div>
}

<div class="card-clean mb-5 p-0">
    <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
            <thead class="bg-light text-muted text-uppercase fw-bold" style="font-size:0.8rem;letter-spacing:0.5px;">
                <tr>
                    <th class="ps-5 py-3 border-0">B_id</th>
                    <th class="py-3 border-0">J_id</th>
                    <th class="py-3 border-0">Parts</th>
                    <th class="py-3 border-0">Part Cost</th>
                    <th class="py-3 border-0">GST</th>
                    <th class="py-3 border-0">Total</th>
                    <th class="py-3 border-0">Status</th>
                    <th class="py-3 border-0">Payment</th>
                    <th class="text-center pe-5 py-3 border-0">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var b in Model)
                {
                    var sc = b.Status switch {
                        "Paid"    => "success",
                        "Overdue" => "danger",
                        _         => "warning"
                    };
                    // Parse parts count
                    int partsCount = 0;
                    if (!string.IsNullOrEmpty(b.Parts_Detail))
                    {
                        try {
                            var arr = System.Text.Json.JsonSerializer.Deserialize<System.Text.Json.JsonElement[]>(b.Parts_Detail);
                            partsCount = arr?.Length ?? 0;
                        } catch { }
                    }
                    <tr class="border-bottom text-dark">
                        <td class="ps-5 py-3 fw-bold text-primary font-monospace">#@b.B_id</td>
                        <td class="fw-bold font-monospace">#@b.J_id</td>
                        <td class="py-3">
                            @if (partsCount > 0)
                            {
                                <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-2 py-1 fw-bold">
                                    <i class="fa-solid fa-box me-1"></i>@partsCount part(s)
                                </span>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td class="text-muted font-monospace">₹@b.Part_cost</td>
                        <td class="text-muted font-monospace">₹@b.Gst</td>
                        <td class="fw-bolder text-dark fs-5 font-monospace">₹@b.Total_cost</td>
                        <td>
                            <div class="dropdown">
                                <button class="btn btn-sm fw-bold border-0 shadow-sm bg-@sc bg-opacity-10 text-@sc dropdown-toggle"
                                        type="button" data-bs-toggle="dropdown"
                                        style="width:115px;border-radius:8px;font-size:0.82rem;">
                                    @b.Status
                                </button>
                                <ul class="dropdown-menu border-0 shadow-lg p-2" style="border-radius:12px;min-width:115px;">
                                    <li>
                                        <form method="post" action="/Admin/UpdateBillingStatus">
                                            <input type="hidden" name="id" value="@b.B_id" />
                                            <input type="hidden" name="status" value="Pending" />
                                            <button type="submit" class="dropdown-item fw-bold text-warning rounded @(b.Status=="Pending"?"bg-warning bg-opacity-10":"") mb-1" style="font-size:0.85rem;">
                                                <i class="fa-solid fa-clock me-1"></i>Pending
                                            </button>
                                        </form>
                                    </li>
                                    <li>
                                        <form method="post" action="/Admin/UpdateBillingStatus">
                                            <input type="hidden" name="id" value="@b.B_id" />
                                            <input type="hidden" name="status" value="Paid" />
                                            <button type="submit" class="dropdown-item fw-bold text-success rounded @(b.Status=="Paid"?"bg-success bg-opacity-10":"") mb-1" style="font-size:0.85rem;">
                                                <i class="fa-solid fa-circle-check me-1"></i>Paid
                                            </button>
                                        </form>
                                    </li>
                                    <li>
                                        <form method="post" action="/Admin/UpdateBillingStatus">
                                            <input type="hidden" name="id" value="@b.B_id" />
                                            <input type="hidden" name="status" value="Overdue" />
                                            <button type="submit" class="dropdown-item fw-bold text-danger rounded @(b.Status=="Overdue"?"bg-danger bg-opacity-10":"")" style="font-size:0.85rem;">
                                                <i class="fa-solid fa-circle-exclamation me-1"></i>Overdue
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                        </td>
                        <td class="text-muted fw-bold">@b.Payment_type</td>
                        <td class="text-center pe-5">
                            <!-- Download PDF -->
                            <a href="/Admin/DownloadInvoice?id=@b.B_id"
                               class="btn btn-sm btn-light text-primary rounded-circle shadow-sm me-2 hover-elevate"
                               style="width:38px;height:38px;display:inline-flex;align-items:center;justify-content:center;"
                               title="Download Invoice PDF">
                                <i class="fa-solid fa-file-pdf"></i>
                            </a>
                            <!-- Delete -->
                            <form method="post" action="/Admin/DeleteBilling" class="d-inline"
                                  onsubmit="return confirm('Delete billing record #@b.B_id?')">
                                <input type="hidden" name="id" value="@b.B_id" />
                                <button class="btn btn-sm btn-light text-danger rounded-circle shadow-sm hover-elevate"
                                        style="width:38px;height:38px;" title="Delete">
                                    <i class="fa-solid fa-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="9" class="text-center text-muted py-5">No billing records found.</td></tr>
                }
            </tbody>
        </table>
    </div>
    <div class="p-4 border-top border-light">
        <span class="text-muted fw-medium">@Model.Count record(s)</span>
    </div>
</div>

<!-- Compile Invoice Modal -->
<div class="modal fade" id="createInvoiceModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0">
            <div class="modal-header">
                <h5 class="modal-title d-flex align-items-center fs-4">
                    <div class="bg-primary bg-opacity-10 text-primary rounded p-2 me-3">
                        <i class="fa-solid fa-file-invoice-dollar"></i>
                    </div>
                    Compile Invoice
                </h5>
                <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" action="/Admin/AddBilling" id="billingForm" novalidate>
                <input type="hidden" name="partsJson" id="partsJsonInput">
                <div class="modal-body p-4">
                    <div class="row g-3">

                        <!-- Job Card -->
                        <div class="col-12">
                            <label class="custom-label"><i class="fa-solid fa-wrench"></i> Job Card (J_id)</label>
                            <select name="J_id" id="bJobId" class="form-select fw-bold">
                                <option value="" disabled selected>Select job card...</option>
                                @foreach (var jid in jobIds)
                                {
                                    <option value="@jid">#@jid</option>
                                }
                            </select>
                            <small class="text-danger fw-medium d-none" id="err-bJobId"></small>
                        </div>

                        <!-- Parts Section -->
                        <div class="col-12">
                            <label class="custom-label"><i class="fa-solid fa-boxes-stacked text-primary"></i> Parts / Services Used</label>
                            <div class="border rounded-3 p-3" style="background:#f8fafc;">
                                <div id="partsContainer">
                                    <!-- Part rows injected here -->
                                </div>
                                <button type="button" class="btn btn-sm btn-outline-primary rounded-pill mt-2 fw-bold" onclick="addPartRow()">
                                    <i class="fa-solid fa-plus me-1"></i> Add Part
                                </button>
                            </div>
                        </div>

                        <!-- Costs -->
                        <div class="col-md-6">
                            <label class="custom-label"><i class="fa-solid fa-box"></i> Total Part Cost</label>
                            <input type="number" name="Part_cost" id="partCost" class="form-control fw-bold bg-light" placeholder="0" readonly>
                        </div>
                        <div class="col-md-6">
                            <label class="custom-label"><i class="fa-solid fa-percent"></i> GST Amount <span class="badge bg-primary bg-opacity-10 text-primary ms-1" style="font-size:0.7rem;">16% Auto</span></label>
                            <input type="number" name="Gst" id="gstVal" class="form-control fw-bold bg-light" placeholder="0" readonly>
                        </div>
                        <div class="col-12">
                            <label class="custom-label"><i class="fa-solid fa-calculator"></i> Total Cost</label>
                            <input type="number" name="Total_cost" id="totalCost"
                                   class="form-control fw-bold text-success fs-5 bg-success bg-opacity-10 border-success border-opacity-25"
                                   placeholder="0" readonly>
                        </div>
                        <div class="col-md-6">
                            <label class="custom-label"><i class="fa-solid fa-circle-half-stroke"></i> Status</label>
                            <select name="Status" class="form-select fw-bold">
                                <option value="Pending" selected>Pending</option>
                                <option value="Paid">Paid</option>
                                <option value="Overdue">Overdue</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="custom-label"><i class="fa-solid fa-credit-card"></i> Payment Type</label>
                            <select name="Payment_type" class="form-select fw-bold">
                                <option value="Cash">Cash</option>
                                <option value="Credit Card">Credit Card</option>
                                <option value="UPI">UPI</option>
                                <option value="Bank Transfer">Bank Transfer</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 pb-4">
                    <button type="button" class="btn btn-light rounded-pill px-4 fw-bold" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-animated rounded-pill px-5" onclick="submitBillingForm()">
                        <i class="fa-solid fa-save me-2"></i> Save Invoice
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .table-hover tbody tr:hover { background-color:#f8fafc; }
    .hover-elevate:hover { transform:translateY(-2px); box-shadow:0 4px 10px rgba(0,0,0,0.1) !important; background:white !important; }
    .part-row { display:flex; gap:8px; align-items:center; margin-bottom:8px; }
    .part-row input { border-radius:8px; border:1px solid #e2e8f0; padding:8px 12px; font-size:0.9rem; background:#fff; }
    .part-row input:focus { border-color:#4338ca; outline:none; box-shadow:0 0 0 3px rgba(67,56,202,0.1); }
    .dropdown-menu { position:fixed !important; }
</style>

@section Scripts {
<script>
    // Fix dropdown clipping
    document.querySelectorAll('[data-bs-toggle="dropdown"]').forEach(btn => {
        btn.addEventListener('shown.bs.dropdown', function () {
            const menu = this.nextElementSibling;
            const rect = this.getBoundingClientRect();
            menu.style.top  = (rect.bottom + 4) + 'px';
            menu.style.left = rect.left + 'px';
        });
    });

    let partCount = 0;

    function addPartRow() {
        partCount++;
        const container = document.getElementById('partsContainer');
        const div = document.createElement('div');
        div.className = 'part-row';
        div.id = 'part-' + partCount;
        div.innerHTML = `
            <input type="text" placeholder="Part / Service name" class="part-name flex-grow-1" style="min-width:0;" oninput="recalc()">
            <input type="number" placeholder="Price (₹)" class="part-price" style="width:120px;" min="0" oninput="recalc()">
            <button type="button" class="btn btn-sm btn-light text-danger rounded-circle" style="width:32px;height:32px;flex-shrink:0;"
                    onclick="removePart('part-${partCount}')">
                <i class="fa-solid fa-xmark" style="font-size:0.75rem;"></i>
            </button>`;
        container.appendChild(div);
    }

    function removePart(id) {
        document.getElementById(id)?.remove();
        recalc();
    }

    function recalc() {
        let total = 0;
        document.querySelectorAll('.part-price').forEach(inp => {
            total += parseInt(inp.value) || 0;
        });
        document.getElementById('partCost').value = total;
        // Auto calculate 16% GST
        const gst = Math.round(total * 0.16);
        document.getElementById('gstVal').value = gst;
        calcTotal();
    }

    function calcTotal() {
        const p = parseInt(document.getElementById('partCost').value) || 0;
        const g = parseInt(document.getElementById('gstVal').value) || 0;
        document.getElementById('totalCost').value = p + g;
    }

    function buildPartsJson() {
        const parts = [];
        document.querySelectorAll('.part-row').forEach(row => {
            const name  = row.querySelector('.part-name').value.trim();
            const price = parseInt(row.querySelector('.part-price').value) || 0;
            if (name) parts.push({ name, price });
        });
        document.getElementById('partsJsonInput').value = JSON.stringify(parts);
    }

    function submitBillingForm() {
        let ok = true;
        const jobId = document.getElementById('bJobId').value;
        const errJobId = document.getElementById('err-bJobId');
        errJobId.classList.add('d-none');
        document.getElementById('bJobId').style.borderColor = '';
        if (!jobId) {
            document.getElementById('bJobId').style.borderColor = '#dc2626';
            document.getElementById('bJobId').style.boxShadow = '0 0 0 3px rgba(220,38,38,0.12)';
            errJobId.textContent = 'Please select a job card.';
            errJobId.classList.remove('d-none');
            ok = false;
        }
        const parts = [];
        document.querySelectorAll('.part-row').forEach(row => {
            const name  = row.querySelector('.part-name').value.trim();
            const price = parseInt(row.querySelector('.part-price').value) || 0;
            if (name) parts.push({ name, price });
        });
        if (parts.length === 0) {
            alert('Please add at least one part or service.'); ok = false;
        }
        if (ok) {
            document.getElementById('partsJsonInput').value = JSON.stringify(parts);
            document.getElementById('billingForm').submit();
        }
    }

    document.getElementById('bJobId')?.addEventListener('change', function() {
        this.style.borderColor = '';
        this.style.boxShadow = '';
        document.getElementById('err-bJobId').classList.add('d-none');
    });

    // Add one row by default when modal opens
    document.getElementById('createInvoiceModal').addEventListener('show.bs.modal', function () {
        document.getElementById('partsContainer').innerHTML = '';
        partCount = 0;
        document.getElementById('partCost').value = '';
        document.getElementById('gstVal').value = '';
        document.getElementById('totalCost').value = '';
        addPartRow();
    });
</script>
}
