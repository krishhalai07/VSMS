@{
    ViewData["Title"] = "Billing";
    Layout = "~/Views/Admin/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-5">
    <div>
        <h1 class="page-header mb-1">Financial Ledgers</h1>
        <p class="text-muted"><i class="fa-solid fa-file-invoice-dollar me-2 text-primary"></i>Process invoices, payments, and digital receipts</p>
    </div>
    <button type="button" class="btn-animated" data-bs-toggle="modal" data-bs-target="#createInvoiceModal">
        <i class="fa-solid fa-money-bill-transfer me-2"></i> Compile Invoice
    </button>
</div>

<div class="card-clean mb-5 p-0">
    <div class="table-responsive p-0" style="overflow-x: visible;">
        <table class="table table-hover table-custom mb-0 align-middle">
            <thead class="bg-light text-muted text-uppercase fw-bold" style="font-size: 0.8rem; letter-spacing: 0.5px;">
                <tr>
                    <th class="ps-5 py-3 border-0">B_id</th>
                    <th class="py-3 border-0">J_id</th>
                    <th class="py-3 border-0">Part_cost</th>
                    <th class="py-3 border-0">Gst</th>
                    <th class="py-3 border-0">Total_cost</th>
                    <th class="py-3 border-0">Status</th>
                    <th class="py-3 border-0">Payment_type</th>
                    <th class="text-center pe-5 py-3 border-0">Actions</th>
                </tr>
            </thead>
            <tbody>
                <!-- Billing 1 -->
                <tr class="border-bottom text-dark">
                    <td class="ps-5 py-4 fw-bold text-primary font-monospace fs-5">1</td>
                    <td class="fw-bold">1001</td>
                    <td class="text-muted fw-medium font-monospace">500</td>
                    <td class="text-muted fw-medium font-monospace">50</td>
                    <td class="fw-bolder text-dark fs-5 font-monospace">550</td>
                    <td>
                        <div class="dropdown">
                            <button class="btn btn-sm fw-bold border-0 shadow-sm bg-success bg-opacity-10 text-success dropdown-toggle d-flex justify-content-between align-items-center" type="button" data-bs-toggle="dropdown" aria-expanded="false" style="width: 130px; border-radius: 8px;">
                                Paid
                            </button>
                            <ul class="dropdown-menu shadow-lg border-0 p-2 bg-white" style="border-radius: 12px; min-width: 130px; z-index: 1050;">
                                <li><a class="dropdown-item fw-bold text-success rounded bg-success bg-opacity-10 mb-1" href="#" onclick="updateBillingStatus(event, this, 'Paid', 'success')">Paid</a></li>
                                <li><a class="dropdown-item fw-bold text-warning rounded transition-hover mb-1" href="#" onclick="updateBillingStatus(event, this, 'Pending', 'warning')">Pending</a></li>
                                <li><a class="dropdown-item fw-bold text-danger rounded transition-hover" href="#" onclick="updateBillingStatus(event, this, 'Overdue', 'danger')">Overdue</a></li>
                            </ul>
                        </div>
                    </td>
                    <td class="text-muted fw-bold"><i class="fa-solid fa-credit-card me-2 text-primary"></i>Credit Card</td>
                    <td class="text-center pe-5">
                        <button class="btn btn-sm btn-light text-primary rounded-circle shadow-sm me-2 hover-elevate" style="width: 38px; height: 38px;" title="View PDF" onclick="showToast('Invoice PDF preview generated successfully', 'success')"><i class="fa-solid fa-file-pdf"></i></button>
                        <button class="btn btn-sm btn-light text-secondary rounded-circle shadow-sm hover-elevate" style="width: 38px; height: 38px;" title="Send via Email" onclick="showToast('Invoice successfully sent to client email', 'primary')"><i class="fa-solid fa-paper-plane"></i></button>
                    </td>
                </tr>

                <!-- Billing 2 -->
                <tr class="border-bottom text-dark">
                    <td class="ps-5 py-4 fw-bold text-primary font-monospace fs-5">2</td>
                    <td class="fw-bold">1002</td>
                    <td class="text-muted fw-medium font-monospace">85</td>
                    <td class="text-muted fw-medium font-monospace">8</td>
                    <td class="fw-bolder text-dark fs-5 font-monospace">93</td>
                    <td>
                        <div class="dropdown">
                            <button class="btn btn-sm fw-bold border-0 shadow-sm bg-warning bg-opacity-10 text-warning dropdown-toggle d-flex justify-content-between align-items-center" type="button" data-bs-toggle="dropdown" aria-expanded="false" style="width: 130px; border-radius: 8px;">
                                Pending
                            </button>
                            <ul class="dropdown-menu shadow-lg border-0 p-2 bg-white" style="border-radius: 12px; min-width: 130px; z-index: 1050;">
                                <li><a class="dropdown-item fw-bold text-success rounded transition-hover mb-1" href="#" onclick="updateBillingStatus(event, this, 'Paid', 'success')">Paid</a></li>
                                <li><a class="dropdown-item fw-bold text-warning rounded bg-warning bg-opacity-10 mb-1" href="#" onclick="updateBillingStatus(event, this, 'Pending', 'warning')">Pending</a></li>
                                <li><a class="dropdown-item fw-bold text-danger rounded transition-hover" href="#" onclick="updateBillingStatus(event, this, 'Overdue', 'danger')">Overdue</a></li>
                            </ul>
                        </div>
                    </td>
                    <td class="text-muted fw-bold"><i class="fa-solid fa-money-bill-wave me-2 text-success"></i>Cash</td>
                    <td class="text-center pe-5">
                        <button class="btn btn-sm btn-light text-primary rounded-circle shadow-sm me-2 hover-elevate" style="width: 38px; height: 38px;" title="View PDF" onclick="showToast('Invoice PDF preview generated successfully', 'success')"><i class="fa-solid fa-file-pdf"></i></button>
                        <button class="btn btn-sm btn-light text-secondary rounded-circle shadow-sm hover-elevate" style="width: 38px; height: 38px;" title="Send via Email" onclick="showToast('Invoice successfully sent to client email', 'primary')"><i class="fa-solid fa-paper-plane"></i></button>
                    </td>
                </tr>

                <!-- Billing 3 -->
                <tr class="border-bottom text-dark">
                    <td class="ps-5 py-4 fw-bold text-primary font-monospace fs-5">3</td>
                    <td class="fw-bold">1003</td>
                    <td class="text-muted fw-medium font-monospace">250</td>
                    <td class="text-muted fw-medium font-monospace">25</td>
                    <td class="fw-bolder text-dark fs-5 font-monospace">275</td>
                    <td>
                        <div class="dropdown">
                            <button class="btn btn-sm fw-bold border-0 shadow-sm bg-danger bg-opacity-10 text-danger dropdown-toggle d-flex justify-content-between align-items-center" type="button" data-bs-toggle="dropdown" aria-expanded="false" style="width: 130px; border-radius: 8px;">
                                Overdue
                            </button>
                            <ul class="dropdown-menu shadow-lg border-0 p-2 bg-white" style="border-radius: 12px; min-width: 130px; z-index: 1050;">
                                <li><a class="dropdown-item fw-bold text-success rounded transition-hover mb-1" href="#" onclick="updateBillingStatus(event, this, 'Paid', 'success')">Paid</a></li>
                                <li><a class="dropdown-item fw-bold text-warning rounded transition-hover mb-1" href="#" onclick="updateBillingStatus(event, this, 'Pending', 'warning')">Pending</a></li>
                                <li><a class="dropdown-item fw-bold text-danger rounded bg-danger bg-opacity-10" href="#" onclick="updateBillingStatus(event, this, 'Overdue', 'danger')">Overdue</a></li>
                            </ul>
                        </div>
                    </td>
                    <td class="text-muted fw-bold"><i class="fa-solid fa-qrcode me-2 text-dark"></i>UPI</td>
                    <td class="text-center pe-5">
                        <button class="btn btn-sm btn-light text-primary rounded-circle shadow-sm me-2 hover-elevate" style="width: 38px; height: 38px;" title="View PDF" onclick="showToast('Invoice PDF preview generated successfully', 'success')"><i class="fa-solid fa-file-pdf"></i></button>
                        <button class="btn btn-sm btn-light text-secondary rounded-circle shadow-sm hover-elevate" style="width: 38px; height: 38px;" title="Send via Email" onclick="showToast('Invoice successfully sent to client email', 'primary')"><i class="fa-solid fa-paper-plane"></i></button>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="createInvoiceModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0">
            <div class="modal-header d-flex flex-column align-items-start border-0 pb-0 pt-4 px-5">
                <h5 class="modal-title text-dark fw-bold fs-3 letter-spacing-1 d-flex align-items-center">
                    <div class="bg-primary bg-opacity-10 text-primary rounded p-2 me-3 fs-4">
                        <i class="fa-solid fa-file-invoice-dollar"></i>
                    </div>
                    GENERATE BILLING
                </h5>
                <button type="button" class="btn-close position-absolute shadow-none" style="top:25px; right: 25px;" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            
            <div class="modal-body p-5 pt-4">
                <form>
                    <div class="row g-4 mb-2">
                        <div class="col-md-6" style="animation: slideUpFade 0.4s both 0.1s;">
                            <div>
                                <label for="bId" class="custom-label"><i class="fa-solid fa-hashtag"></i>B_id</label>
                                <input type="number" class="form-control font-monospace fw-bold text-primary" id="bId" placeholder="e.g. 1" required>
                            </div>
                        </div>
                        <div class="col-md-6" style="animation: slideUpFade 0.4s both 0.1s;">
                            <div>
                                <label for="jId" class="custom-label"><i class="fa-solid fa-wrench"></i>J_id</label>
                                <input type="number" class="form-control font-monospace fw-bold" id="jId" placeholder="e.g. 1001" required>
                            </div>
                        </div>
                        <div class="col-md-6" style="animation: slideUpFade 0.4s both 0.2s;">
                            <div>
                                <label for="partCost" class="custom-label"><i class="fa-solid fa-box"></i>Part_cost</label>
                                <input type="number" class="form-control fw-bold" id="partCost" placeholder="0" required>
                            </div>
                        </div>
                        <div class="col-md-6" style="animation: slideUpFade 0.4s both 0.2s;">
                            <div>
                                <label for="gst" class="custom-label"><i class="fa-solid fa-percent"></i>Gst</label>
                                <input type="number" class="form-control fw-bold" id="gst" placeholder="0" required>
                            </div>
                        </div>
                        <div class="col-md-12" style="animation: slideUpFade 0.4s both 0.3s;">
                            <div>
                                <label for="totalCost" class="custom-label"><i class="fa-solid fa-calculator"></i>Total_cost</label>
                                <input type="number" class="form-control fw-bold text-success fs-5 bg-success bg-opacity-10 border-success border-opacity-25" id="totalCost" placeholder="0" required>
                            </div>
                        </div>
                        <div class="col-md-6" style="animation: slideUpFade 0.4s both 0.4s;">
                            <div>
                                <label for="Status" class="custom-label"><i class="fa-solid fa-circle-half-stroke"></i>Status</label>
                                <select class="form-select fw-bold text-dark" id="Status" required>
                                    <option value="Paid">Paid</option>
                                    <option value="Pending" selected>Pending</option>
                                    <option value="Overdue">Overdue</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-6" style="animation: slideUpFade 0.4s both 0.4s;">
                            <div>
                                <label for="PaymentType" class="custom-label"><i class="fa-solid fa-credit-card"></i>Payment_type</label>
                                <select class="form-select fw-bold text-dark" id="PaymentType" required>
                                    <option value="Credit Card">Credit Card</option>
                                    <option value="Cash">Cash</option>
                                    <option value="UPI">UPI</option>
                                    <option value="Bank Transfer">Bank Transfer</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer pb-4 pt-3 border-0 justify-content-end px-5">
                <button type="button" class="btn btn-light rounded-pill px-4 fw-bold me-2" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-animated rounded-pill px-5"><i class="fa-solid fa-save me-2"></i> Save Record</button>
            </div>
        </div>
    </div>
</div>

<style>
    .letter-spacing-1 { letter-spacing: 1px; }
    .text-sm { font-size: 0.875rem; }
    .hover-elevate:hover { transform: translateY(-3px); box-shadow: 0 4px 10px rgba(0,0,0,0.1) !important;}
    .hover-lift:hover { background: white; transform: translateY(-1px); box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); }
    .table-hover tbody tr:hover { background-color: #f8fbfd; transition: background-color 0.2s; }
    .transition-hover { transition: all 0.15s ease-in-out; }
    .custom-dropdown-btn::after { margin-left: auto; }
    .transition-hover:hover { background-color: #f1f5f9; color: #0f172a !important; transform: translateX(2px); }
</style>

@section Scripts {
    <script>
        function updateBillingStatus(e, element, status, colorClass) {
            e.preventDefault();
            const btn = element.closest('.dropdown').querySelector('.dropdown-toggle');
            const menuItems = element.closest('.dropdown-menu').querySelectorAll('.dropdown-item');
            
            menuItems.forEach(item => {
                let originalClasses = item.className;
                item.className = originalClasses.replace(/bg-[a-z]+ bg-opacity-10/g, 'transition-hover');
            });

            btn.className = `btn btn-sm fw-bold border-0 shadow-sm bg-${colorClass} bg-opacity-10 text-${colorClass} dropdown-toggle d-flex justify-content-between align-items-center`;
            btn.innerText = status;
            
            element.className = element.className.replace('transition-hover', `bg-${colorClass} bg-opacity-10`);
            
            if (typeof showToast === 'function') {
                showToast(`Billing invoice marked as ${status}`, colorClass === 'danger' ? 'danger' : 'success');
            }

            const dropdownInstance = bootstrap.Dropdown.getOrCreateInstance(btn);
            if (dropdownInstance) {
                dropdownInstance.hide();
            }
        }
    </script>
}
