@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Login - VSMS</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #4338ca 0%, #0ea5e9 100%);
            min-height: 100vh; display: flex; align-items: center; justify-content: center;
            overflow: hidden; position: relative;
        }
        .shape { position: absolute; border-radius: 50%; background: rgba(255,255,255,0.08); animation: float 15s infinite ease-in-out; }
        .shape-1 { width: 420px; height: 420px; top: -120px; left: -120px; }
        .shape-2 { width: 300px; height: 300px; bottom: -60px; right: -60px; animation-delay: -5s; }
        .shape-3 { width: 160px; height: 160px; top: 45%; left: 65%; animation-delay: -10s; }
        @@keyframes float { 0%,100%{transform:translateY(0) rotate(0deg);} 50%{transform:translateY(-20px) rotate(8deg);} }
        .auth-card {
            background: rgba(255,255,255,0.97); border-radius: 24px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.25); padding: 44px 40px;
            width: 100%; max-width: 440px; z-index: 1;
            animation: slideUp 0.7s cubic-bezier(0.16,1,0.3,1) forwards;
        }
        @@keyframes slideUp { from{opacity:0;transform:translateY(40px);} to{opacity:1;transform:translateY(0);} }
        .brand-icon {
            width: 76px; height: 76px;
            background: linear-gradient(135deg, #4338ca, #0ea5e9);
            border-radius: 50%; display: flex; align-items: center; justify-content: center;
            margin: 0 auto 20px; font-size: 30px; color: white;
            box-shadow: 0 8px 24px rgba(67,56,202,0.35);
        }
        .input-wrap { position: relative; margin-bottom: 18px; }
        .input-wrap i { position: absolute; left: 14px; top: 50%; transform: translateY(-50%); color: #94a3b8; z-index: 5; }
        .form-control {
            border-radius: 12px; border: 2px solid #e2e8f0;
            padding: 12px 14px 12px 42px; font-weight: 500; transition: all 0.3s;
        }
        .form-control:focus { border-color: #4338ca; box-shadow: 0 0 0 4px rgba(67,56,202,0.12); }
        .btn-submit {
            width: 100%; background: linear-gradient(135deg, #4338ca, #6366f1);
            color: white; border: none; border-radius: 12px; padding: 13px;
            font-weight: 700; font-size: 15px; transition: all 0.3s;
            box-shadow: 0 6px 18px rgba(67,56,202,0.3); margin-top: 6px;
        }
        .btn-submit:hover { transform: translateY(-2px); box-shadow: 0 10px 25px rgba(67,56,202,0.4); color: white; }
        .divider { display: flex; align-items: center; gap: 12px; margin: 20px 0; }
        .divider hr { flex: 1; border-color: #e2e8f0; }
    </style>
</head>
<body>
    <div class="shape shape-1"></div>
    <div class="shape shape-2"></div>
    <div class="shape shape-3"></div>

    <div class="auth-card">
        <div class="brand-icon"><i class="fa-solid fa-car-wrench"></i></div>
        <h4 class="text-center fw-bold mb-1">VSMS Pro</h4>
        <p class="text-center text-muted mb-4" style="font-size:0.9rem;">Sign in to Admin Console</p>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger rounded-3 py-2 mb-3" style="font-size:0.875rem;">
                <i class="fa-solid fa-circle-exclamation me-2"></i>@ViewBag.Error
            </div>
        }

        <form method="post" action="/Admin/Login">
            <div class="input-wrap">
                <input type="email" name="email" class="form-control" placeholder="Admin Email" required>
                <i class="fa-regular fa-envelope"></i>
            </div>
            <div class="input-wrap">
                <input type="password" name="password" class="form-control" placeholder="Password" required>
                <i class="fa-solid fa-lock"></i>
            </div>
            <button type="submit" class="btn-submit">
                <i class="fa-solid fa-shield-halved me-2"></i>Admin Sign In
            </button>
        </form>

        <div class="divider">
            <hr /><span class="text-muted fw-medium" style="font-size:0.8rem;">OR</span><hr />
        </div>

        <a href="/Customer/Login" class="btn btn-outline-primary w-100 rounded-pill fw-bold py-2">
            <i class="fa-solid fa-user me-2"></i>Customer Portal
        </a>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
