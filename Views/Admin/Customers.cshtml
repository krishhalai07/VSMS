@model List<VSMS.Models.Customer>
@{
    ViewData["Title"] = "Customers";
    Layout = "~/Views/Admin/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-5">
    <div>
        <h1 class="page-header mb-1">Customer Directory</h1>
        <p class="text-muted"><i class="fa-solid fa-users me-2 text-primary"></i>Registered customer accounts</p>
    </div>
</div>

@if (TempData["Toast"] != null)
{
    <div class="alert alert-success rounded-3 py-2 mb-4"><i class="fa-solid fa-circle-check me-2"></i>@TempData["Toast"]</div>
}

<div class="card-clean mb-5 p-0">
    <div class="p-4 border-bottom border-light">
        <div class="search-bar d-flex align-items-center bg-light border" style="width:350px;">
            <i class="fa-solid fa-search text-muted me-2"></i>
            <input type="text" placeholder="Search customers..." class="bg-transparent border-0 w-100 outline-none">
        </div>
    </div>
    <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
            <thead class="bg-light text-muted text-uppercase fw-bold" style="font-size:0.8rem;letter-spacing:0.5px;">
                <tr>
                    <th class="ps-5 py-3 border-0">ID</th>
                    <th class="py-3 border-0">Name</th>
                    <th class="py-3 border-0">Email</th>
                    <th class="py-3 border-0">Contact</th>
                    <th class="text-center pe-5 py-3 border-0">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model)
                {
                    <tr class="border-bottom text-dark">
                        <td class="ps-5 py-3 fw-bold text-primary font-monospace">#@c.Customer_id</td>
                        <td>
                            <div class="d-flex align-items-center">
                                <img src="https://ui-avatars.com/api/?name=@Uri.EscapeDataString(c.Name ?? "?")&background=e0e7ff&color=4338ca&bold=true"
                                     class="rounded-circle shadow-sm me-3" width="40" height="40">
                                <span class="fw-bold">@c.Name</span>
                            </div>
                        </td>
                        <td class="text-muted fw-medium">@c.Email</td>
                        <td class="fw-medium">@c.Contact</td>
                        <td class="text-center pe-5">
                            <button class="btn btn-sm btn-light text-primary rounded-circle shadow-sm me-2 hover-elevate"
                                    style="width:38px;height:38px;" title="View Details"
                                    onclick="showCustomer(@c.Customer_id, '@Html.Raw(c.Name?.Replace("'","\\'")??"")','@c.Email','@c.Contact')">
                                <i class="fa-solid fa-eye"></i>
                            </button>
                            <form method="post" action="/Admin/DeleteCustomer" class="d-inline"
                                  onsubmit="return confirm('Delete this customer?')">
                                <input type="hidden" name="id" value="@c.Customer_id" />
                                <button class="btn btn-sm btn-light text-danger rounded-circle shadow-sm hover-elevate"
                                        style="width:38px;height:38px;" title="Delete">
                                    <i class="fa-solid fa-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="5" class="text-center text-muted py-5">No customers registered yet.</td></tr>
                }
            </tbody>
        </table>
    </div>
    <div class="p-4 border-top border-light">
        <span class="text-muted fw-medium">@Model.Count record(s)</span>
    </div>
</div>

<!-- Single reusable View Modal -->
<div class="modal fade" id="viewCustomerModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title d-flex align-items-center fs-5 fw-bold">
                    <div class="bg-primary bg-opacity-10 text-primary rounded p-2 me-3">
                        <i class="fa-solid fa-address-card"></i>
                    </div>
                    Client Details
                </h5>
                <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <div class="text-center mb-4 pb-3 border-bottom">
                    <img id="modal-avatar" src="" class="rounded-circle shadow mb-3" width="80" height="80">
                    <h5 class="fw-bolder text-dark mb-0" id="modal-name"></h5>
                    <small class="text-muted font-monospace" id="modal-id"></small>
                </div>
                <div class="row g-3">
                    <div class="col-12">
                        <div class="d-flex align-items-center p-3 bg-light rounded-3 border">
                            <div class="text-primary me-3" style="width:36px;text-align:center;">
                                <i class="fa-regular fa-envelope fs-5"></i>
                            </div>
                            <div>
                                <div class="text-muted fw-semibold" style="font-size:0.75rem;text-transform:uppercase;">Email Address</div>
                                <div class="fw-bold text-dark" id="modal-email"></div>
                            </div>
                        </div>
                    </div>
                    <div class="col-12">
                        <div class="d-flex align-items-center p-3 bg-light rounded-3 border">
                            <div class="text-success me-3" style="width:36px;text-align:center;">
                                <i class="fa-solid fa-phone fs-5"></i>
                            </div>
                            <div>
                                <div class="text-muted fw-semibold" style="font-size:0.75rem;text-transform:uppercase;">Contact Number</div>
                                <div class="fw-bold text-dark" id="modal-contact"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0 pt-0 pb-4 justify-content-center">
                <button type="button" class="btn btn-animated rounded-pill px-5" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<style>
    .table-hover tbody tr:hover { background-color:#f8fafc; }
    .hover-elevate:hover { transform: translateY(-2px); box-shadow: 0 4px 10px rgba(0,0,0,0.1) !important; background: white !important; }
</style>

@section Scripts {
<script>
    function showCustomer(id, name, email, contact) {
        document.getElementById('modal-name').textContent    = name;
        document.getElementById('modal-id').textContent      = '#CUST-' + id;
        document.getElementById('modal-email').textContent   = email || '—';
        document.getElementById('modal-contact').textContent = contact || '—';
        document.getElementById('modal-avatar').src =
            'https://ui-avatars.com/api/?name=' + encodeURIComponent(name) +
            '&background=e0e7ff&color=4338ca&bold=true&size=100';
        new bootstrap.Modal(document.getElementById('viewCustomerModal')).show();
    }
</script>
}
