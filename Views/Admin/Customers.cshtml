@{
    ViewData["Title"] = "Customers";
    Layout = "~/Views/Admin/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-5">
    <div>
        <h1 class="page-header mb-1">Customer Directory</h1>
        <p class="text-muted"><i class="fa-solid fa-users me-2 text-primary"></i>Manage your entire client base and records</p>
    </div>

</div>

<div class="card-clean mb-5 p-0">
    <div class="d-flex justify-content-between align-items-center p-4 border-bottom border-light">
        <div class="search-bar d-flex align-items-center bg-light border" style="width: 350px;">
            <i class="fa-solid fa-search text-muted me-2"></i>
            <input type="text" placeholder="Search customers..." class="bg-transparent border-0 w-100 outline-none">
        </div>
        <button class="btn btn-outline-secondary rounded-pill px-4 fw-medium"><i class="fa-solid fa-filter me-2 text-primary"></i>Filter View</button>
    </div>

    <div class="table-responsive p-0">
        <table class="table table-hover table-custom mb-0 align-middle">
            <thead class="bg-light text-muted text-uppercase fw-bold" style="font-size: 0.8rem; letter-spacing: 0.5px;">
                <tr>
                    <th class="ps-5 py-3 border-0">Client Identity</th>
                    <th class="py-3 border-0">Email Address</th>
                    <th class="py-3 border-0">Contact Number</th>
                    <th class="text-center pe-5 py-3 border-0">Actions</th>
                </tr>
            </thead>
            <tbody>
                <!-- Customer 1 -->
                <tr class="border-bottom text-dark">
                    <td class="ps-5 py-4">
                        <div class="d-flex align-items-center">
                            <img src="https://ui-avatars.com/api/?name=John+Doe&background=e0e7ff&color=4338ca&bold=true" class="rounded-circle shadow-sm me-3" width="48" height="48">
                            <div>
                                <h6 class="mb-0 fw-bold">John Doe</h6>
                                <small class="text-muted fw-medium font-monospace">#CUST-01</small>
                            </div>
                        </div>
                    </td>
                    <td><span class="text-muted fw-medium"><i class="fa-solid fa-envelope me-2 text-muted"></i>john.doe@email.com</span></td>
                    <td><span class="fw-bold text-dark"><i class="fa-solid fa-phone me-2 text-secondary"></i>1234567890</span></td>
                    <td class="text-center pe-5">
                        <button class="btn btn-sm btn-light text-primary rounded-circle shadow-sm me-2 hover-elevate" data-bs-toggle="modal" data-bs-target="#viewCustomerModal-1" title="View Client Details" style="width: 38px; height: 38px;"><i class="fa-solid fa-eye"></i></button>
                        <button class="btn btn-sm btn-light text-danger rounded-circle shadow-sm hover-elevate" data-bs-toggle="modal" data-bs-target="#deleteConfirmationModal" title="Delete Client" style="width: 38px; height: 38px;"><i class="fa-solid fa-trash"></i></button>
                    </td>
                </tr>
                
                <!-- Customer 2 -->
                <tr class="border-bottom text-dark">
                    <td class="ps-5 py-4">
