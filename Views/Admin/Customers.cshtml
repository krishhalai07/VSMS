    </div>
</div>

<!-- View Customer Modal 1 -->
<div class="modal fade" id="viewCustomerModal-1" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0" style="z-index: 1055;">
            <div class="modal-header">
                <h5 class="modal-title d-flex align-items-center fs-4">
                    <div class="bg-primary bg-opacity-10 text-primary rounded p-2 me-3">
                        <i class="fa-solid fa-address-card"></i>
                    </div>
                    Client Details
                </h5>
                <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            
            <div class="modal-body p-4 pt-4">
                <div class="text-center mb-4 pb-3 border-bottom border-light">
                    <img src="https://ui-avatars.com/api/?name=John+Doe&background=e0e7ff&color=4338ca&bold=true&size=100" class="rounded-circle shadow-sm border mb-3" width="80" height="80">
                    <h4 class="fw-bolder text-dark mb-0">John Doe</h4>
                </div>
                
                <div class="row g-4">
                    <div class="col-md-6" style="animation: slideUpFade 0.4s both 0.1s;">
                        <h6 class="custom-label mb-1"><i class="fa-solid fa-hashtag"></i> Customer_id</h6>
                        <p class="fw-bold text-dark fs-5 mb-0 font-monospace">#CUST-01</p>
                    </div>
                    <div class="col-md-6" style="animation: slideUpFade 0.4s both 0.2s;">
                        <h6 class="custom-label mb-1"><i class="fa-solid fa-phone"></i> Contact</h6>
                        <p class="fw-bold text-dark fs-5 mb-0">1234567890</p>
                    </div>
                    <div class="col-12" style="animation: slideUpFade 0.4s both 0.2s;">
                        <h6 class="custom-label mb-1"><i class="fa-regular fa-envelope"></i> Email</h6>
                        <p class="fw-bold text-dark fs-5 mb-0" style="font-size: 1rem !important;">john.doe@email.com</p>
                    </div>
                    <div class="col-12" style="animation: slideUpFade 0.4s both 0.3s;">
                        <h6 class="custom-label mb-2"><i class="fa-solid fa-car-side text-primary"></i> Registered Vehicles</h6>
                        <div class="d-flex align-items-center p-3 border rounded shadow-sm hover-elevate transition-hover bg-white" style="cursor: pointer;">
                            <div class="p-2 bg-primary bg-opacity-10 text-primary rounded shadow-sm me-3 border border-primary border-opacity-25">
                                <i class="fa-solid fa-car"></i>
                            </div>
                            <div>
                                <h6 class="mb-0 fw-bold text-dark">Toyota Camry</h6>
                                <p class="mb-0 text-muted fw-bold text-sm font-monospace">ABC-1234 &bull; 2019</p>
                            </div>
                            <div class="ms-auto">
                                <i class="fa-solid fa-chevron-right text-muted"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0 pb-4 pt-2 justify-content-center">
                <button type="button" class="btn btn-animated rounded-pill px-5" data-bs-dismiss="modal">Close Details</button>
            </div>
        </div>
    </div>
</div>

