@{
    ViewData["Title"] = "Mechanics";
    Layout = "~/Views/Admin/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-5">
    <div>
        <h1 class="page-header mb-1">Workshop Specialists</h1>
        <p class="text-muted"><i class="fa-solid fa-user-ninja me-2 text-primary"></i>Manage your team of certified mechanical operators</p>
    </div>
    <button type="button" class="btn-animated" data-bs-toggle="modal" data-bs-target="#addMechanicModal">
        <i class="fa-solid fa-plus me-2"></i> Add Specialist
    </button>
</div>

<!-- Cards omitted for brevity -->
<div class="row g-4 mb-5">
    <!-- Mechanic 1 -->
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card-clean text-center overflow-hidden h-100">
            <div class="bg-primary" style="height: 60px;"></div>
            <div class="px-4 pb-4 position-relative" style="margin-top: -40px;">
                <img src="https://ui-avatars.com/api/?name=David+Miller&background=fff&color=4338ca&bold=true&size=100" class="rounded-circle mb-3 bg-white p-1 shadow-sm" style="border: 2px solid #e2e8f0;">
                
                <h5 class="fw-bolder text-dark mb-1">David Miller</h5>
                <p class="text-primary fw-bold text-sm mb-4"><i class="fa-solid fa-microchip me-1"></i> Engine Specialist</p>
                
                <div class="d-flex justify-content-center border-top border-bottom py-3 mb-4">
                    <div class="px-3 border-end">
                        <div class="text-muted fw-bold text-sm text-uppercase">Experience</div>
                        <div class="fw-bolder fs-5 text-dark">8 Yrs</div>
                    </div>
                    <div class="px-3">
                        <div class="text-muted fw-bold text-sm text-uppercase">Badge</div>
                        <div class="fw-bolder fs-5 text-dark">#MCH-01</div>
                    </div>
                </div>
                
                <div class="d-flex justify-content-between align-items-center">
                    <span class="badge bg-warning bg-opacity-10 text-warning border border-warning border-opacity-25 rounded-pill px-4 py-2 fw-bold">ON JOB (JC-1001)</span>
                    <div>
                        <button class="btn btn-light text-primary rounded-circle shadow-sm hover-elevate" data-bs-toggle="modal" data-bs-target="#addMechanicModal" title="Edit Profile"><i class="fa-solid fa-pen text-sm"></i></button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Mechanic 2 -->
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card-clean text-center overflow-hidden h-100">
            <div class="bg-success" style="height: 60px;"></div>
            <div class="px-4 pb-4 position-relative" style="margin-top: -40px;">
                <img src="https://ui-avatars.com/api/?name=Sarah+Jenkins&background=fff&color=10b981&bold=true&size=100" class="rounded-circle mb-3 bg-white p-1 shadow-sm" style="border: 2px solid #e2e8f0;">
                
                <h5 class="fw-bolder text-dark mb-1">Sarah Jenkins</h5>
                <p class="text-success fw-bold text-sm mb-4"><i class="fa-solid fa-laptop-medical me-1"></i> Diagnostics Lead</p>
                
                <div class="d-flex justify-content-center border-top border-bottom py-3 mb-4">
                    <div class="px-3 border-end">
                        <div class="text-muted fw-bold text-sm text-uppercase">Experience</div>
                        <div class="fw-bolder fs-5 text-dark">12 Yrs</div>
                    </div>
                    <div class="px-3">
                        <div class="text-muted fw-bold text-sm text-uppercase">Badge</div>
                        <div class="fw-bolder fs-5 text-dark">#MCH-02</div>
                    </div>
                </div>
                
                <div class="d-flex justify-content-between align-items-center">
                    <span class="badge bg-warning bg-opacity-10 text-warning border border-warning border-opacity-25 rounded-pill px-4 py-2 fw-bold">ON JOB (JC-1002)</span>
                    <div>
                        <button class="btn btn-light text-primary rounded-circle shadow-sm hover-elevate" data-bs-toggle="modal" data-bs-target="#addMechanicModal" title="Edit Profile"><i class="fa-solid fa-pen text-sm"></i></button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Mechanic 3 -->
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card-clean text-center overflow-hidden h-100">
            <div class="bg-secondary" style="height: 60px;"></div>
            <div class="px-4 pb-4 position-relative" style="margin-top: -40px;">
                <img src="https://ui-avatars.com/api/?name=Marcus+Vance&background=fff&color=64748b&bold=true&size=100" class="rounded-circle mb-3 bg-white p-1 shadow-sm" style="border: 2px solid #e2e8f0;">
                
                <h5 class="fw-bolder text-dark mb-1">Marcus Vance</h5>
                <p class="text-secondary fw-bold text-sm mb-4"><i class="fa-solid fa-screwdriver-wrench me-1"></i> General Maint.</p>
                
                <div class="d-flex justify-content-center border-top border-bottom py-3 mb-4">
                    <div class="px-3 border-end">
                        <div class="text-muted fw-bold text-sm text-uppercase">Experience</div>
                        <div class="fw-bolder fs-5 text-dark">4 Yrs</div>
                    </div>
                    <div class="px-3">
                        <div class="text-muted fw-bold text-sm text-uppercase">Badge</div>
                        <div class="fw-bolder fs-5 text-dark">#MCH-03</div>
                    </div>
                </div>
                
                <div class="d-flex justify-content-between align-items-center">
                    <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 rounded-pill px-4 py-2 fw-bold">AVAILABLE</span>
                    <div>
                        <button class="btn btn-light text-primary rounded-circle shadow-sm hover-elevate" data-bs-toggle="modal" data-bs-target="#addMechanicModal" title="Edit Profile"><i class="fa-solid fa-pen text-sm"></i></button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="addMechanicModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0">
            <div class="modal-header">
                <h5 class="modal-title d-flex align-items-center fs-4">
                    <div class="bg-primary bg-opacity-10 text-primary rounded p-2 me-3">
                        <i class="fa-solid fa-user-gear"></i>
                    </div>
                    Add Specialist
                </h5>
                <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            
            <div class="modal-body p-4 pt-4">
                <form>
                    <div class="row g-4">
                        <div class="col-12" style="animation: slideUpFade 0.4s both 0.1s;">
                            <div>
                                <label for="mechName" class="custom-label"><i class="fa-regular fa-user"></i>Specialist Name</label>
                                <input type="text" class="form-control fw-bold text-dark" id="mechName" placeholder="Full name..." required>
                            </div>
                        </div>
                        <div class="col-md-6" style="animation: slideUpFade 0.4s both 0.2s;">
                            <div>
                                <label for="mechPhone" class="custom-label"><i class="fa-solid fa-phone"></i>Contact Number</label>
                                <input type="tel" class="form-control" id="mechPhone" placeholder="(555)..." required>
                            </div>
                        </div>
                        <div class="col-md-6" style="animation: slideUpFade 0.4s both 0.3s;">
                            <div>
                                <label for="mechStatus" class="custom-label"><i class="fa-solid fa-toggle-on"></i>Current Status</label>
                                <select class="form-select fw-bold text-dark" id="mechStatus" required>
                                    <option value="Available" selected>Available</option>
                                    <option value="On Job">On Job</option>
                                    <option value="Off">Off Duty</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-6" style="animation: slideUpFade 0.4s both 0.4s;">
                            <div>
                                <label for="mechSpec" class="custom-label"><i class="fa-solid fa-wrench"></i>Specialization</label>
                                <input type="text" class="form-control" id="mechSpec" placeholder="e.g. Engine Repair" required>
                            </div>
                        </div>
                        <div class="col-md-6" style="animation: slideUpFade 0.4s both 0.5s;">
                            <div>
                                <label for="mechExp" class="custom-label"><i class="fa-solid fa-trophy"></i>Years Exp</label>
                                <input type="number" class="form-control" id="mechExp" placeholder="5" min="0" required>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer border-0 pb-4 pt-2">
                <button type="button" class="btn btn-light rounded-pill px-4 fw-bold me-2" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-animated rounded-pill px-5"><i class="fa-solid fa-check me-2"></i> Register Profile</button>
            </div>
        </div>
    </div>
</div>

<style>
    .hover-elevate:hover { transform: translateY(-3px); box-shadow: 0 4px 10px rgba(0,0,0,0.1) !important;}
    .text-sm { font-size: 0.875rem; }
</style>
