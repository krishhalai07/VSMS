@model List<VSMS.Models.Mechanic>
@{
    ViewData["Title"] = "Mechanics";
    Layout = "~/Views/Admin/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-5">
    <div>
        <h1 class="page-header mb-1">Workshop Specialists</h1>
        <p class="text-muted"><i class="fa-solid fa-wrench me-2 text-primary"></i>Manage your mechanic team</p>
    </div>
    <button type="button" class="btn-animated" data-bs-toggle="modal" data-bs-target="#addMechanicModal">
        <i class="fa-solid fa-plus me-2"></i> Add Mechanic
    </button>
</div>

@if (TempData["Toast"] != null)
{
    <div class="alert alert-success rounded-3 py-2 mb-4"><i class="fa-solid fa-circle-check me-2"></i>@TempData["Toast"]</div>
}

<div class="row g-4 mb-5">
    @foreach (var m in Model)
    {
        var badgeClass = m.Status == "Available" ? "success" : m.Status == "Off Duty" ? "secondary" : "warning";
        <div class="col-12 col-md-6 col-xl-4">
            <div class="card-clean text-center overflow-hidden h-100">
                <div class="bg-primary" style="height:55px;"></div>
                <div class="px-4 pb-4 position-relative" style="margin-top:-35px;">
                    <img src="https://ui-avatars.com/api/?name=@Uri.EscapeDataString(m.Mech_Name ?? "M")&background=fff&color=4338ca&bold=true&size=80"
                         class="rounded-circle bg-white p-1 shadow-sm mb-2" style="border:2px solid #e2e8f0;">
                    <h5 class="fw-bolder text-dark mb-3">@m.Mech_Name</h5>
                    <div class="d-flex justify-content-center border-top border-bottom py-3 mb-3">
                        <div class="px-3 border-end w-50">
                            <div class="text-muted fw-bold" style="font-size:0.75rem;">MECH ID</div>
                            <div class="fw-bolder fs-5 text-dark">@m.Mech_id</div>
                        </div>
                        <div class="px-3 w-50">
                            <div class="text-muted fw-bold" style="font-size:0.75rem;">CONTACT</div>
                            <div class="fw-bold text-dark" style="font-size:0.9rem;">@m.Mech_Contact</div>
                        </div>
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="badge bg-@badgeClass bg-opacity-10 text-@badgeClass border border-@badgeClass border-opacity-25 rounded-pill px-3 py-2 fw-bold">
                            @m.Status?.ToUpper()
                        </span>
                        <form method="post" action="/Admin/DeleteMechanic" class="d-inline"
                              onsubmit="return confirm('Delete @m.Mech_Name?')">
                            <input type="hidden" name="id" value="@m.Mech_id" />
                            <button class="btn btn-light text-danger rounded-circle shadow-sm" title="Delete">
                                <i class="fa-solid fa-trash" style="font-size:0.85rem;"></i>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
    @if (!Model.Any())
    {
        <div class="col-12 text-center text-muted py-5">No mechanics added yet.</div>
    }
</div>

<!-- Add Mechanic Modal -->
<div class="modal fade" id="addMechanicModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0">
            <div class="modal-header">
                <h5 class="modal-title d-flex align-items-center fs-4">
                    <div class="bg-primary bg-opacity-10 text-primary rounded p-2 me-3">
                        <i class="fa-solid fa-user-gear"></i>
                    </div>
                    Add Mechanic
                </h5>
                <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" action="/Admin/AddMechanic">
                <div class="modal-body p-4">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="custom-label"><i class="fa-regular fa-user"></i> Name</label>
                            <input type="text" name="Mech_Name" class="form-control" placeholder="Full name" required>
                        </div>
                        <div class="col-md-6">
                            <label class="custom-label"><i class="fa-solid fa-phone"></i> Contact</label>
                            <input type="text" name="Mech_Contact" class="form-control" placeholder="Phone number" required>
                        </div>
                        <div class="col-12">
                            <label class="custom-label"><i class="fa-solid fa-toggle-on"></i> Status</label>
                            <select name="Status" class="form-select fw-bold">
                                <option value="Available">Available</option>
                                <option value="On Job">On Job</option>
                                <option value="Off Duty">Off Duty</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 pb-4">
                    <button type="button" class="btn btn-light rounded-pill px-4 fw-bold" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-animated rounded-pill px-5">
                        <i class="fa-solid fa-check me-2"></i> Save
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
