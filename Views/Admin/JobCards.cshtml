@model List<VSMS.Models.JobCard>
@{
    ViewData["Title"] = "Job Cards";
    Layout = "~/Views/Admin/_Layout.cshtml";
    var vehicles  = ViewBag.Vehicles  as List<VSMS.Models.Vehicle>  ?? new();
    var mechanics = ViewBag.Mechanics as List<VSMS.Models.Mechanic> ?? new();
}

<div class="d-flex justify-content-between align-items-center mb-5">
    <div>
        <h1 class="page-header mb-1">Active Job Cards</h1>
        <p class="text-muted"><i class="fa-solid fa-clipboard-list me-2 text-primary"></i>Track ongoing repairs and workshop tasks</p>
    </div>
    <button type="button" class="btn-animated" data-bs-toggle="modal" data-bs-target="#createJobModal">
        <i class="fa-solid fa-file-circle-plus me-2"></i> Create Job Card
    </button>
</div>

@if (TempData["Toast"] != null)
{
    <div class="alert alert-success rounded-3 py-2 mb-4"><i class="fa-solid fa-circle-check me-2"></i>@TempData["Toast"]</div>
}

<div class="card-clean mb-5 p-0" style="overflow:visible;">
    <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
            <thead class="bg-light text-muted text-uppercase fw-bold" style="font-size:0.8rem;letter-spacing:0.5px;">
                <tr>
                    <th class="ps-5 py-3 border-0">J_id</th>
                    <th class="py-3 border-0">Vech_id</th>
                    <th class="py-3 border-0">Problem</th>
                    <th class="py-3 border-0">Date In</th>
                    <th class="py-3 border-0">Date Out</th>
                    <th class="py-3 border-0">Mechanic</th>
                    <th class="py-3 border-0">Status</th>
                    <th class="text-center pe-5 py-3 border-0">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var j in Model)
                {
                    var sc = j.Status switch {
                        "Completed" or "Delivered" => "success",
                        "In Progress" or "Assigned" => "primary",
                        "Testing" => "warning",
                        _ => "secondary"
                    };
                    <tr class="border-bottom text-dark">
                        <td class="ps-5 py-3 fw-bold text-primary font-monospace">#@j.J_id</td>
                        <td class="fw-bold">@j.Vech_id</td>
                        <td class="text-muted fw-medium">@j.Problem</td>
                        <td class="text-muted">@j.Date_in?.ToString("yyyy-MM-dd")</td>
                        <td class="text-muted">@(j.Date_out.HasValue ? j.Date_out.Value.ToString("yyyy-MM-dd") : "-")</td>
                        <td class="fw-medium"><i class="fa-solid fa-wrench me-2 text-primary"></i>@j.Mech_Name</td>
                        <td>
                            <div class="dropdown">
                                <button class="btn btn-sm fw-bold border-0 shadow-sm bg-@sc bg-opacity-10 text-@sc dropdown-toggle d-flex justify-content-between align-items-center"
                                        type="button" data-bs-toggle="dropdown"
                                        style="width:130px;border-radius:8px;font-size:0.82rem;">
                                    @j.Status
                                </button>
                                <ul class="dropdown-menu border-0 shadow-lg p-2" style="border-radius:12px;min-width:130px;">
                                    @foreach (var s in new[] { "Pending", "Assigned", "In Progress", "Testing", "Completed", "Delivered" })
                                    {
                                        var sc2 = s switch {
                                            "Completed" or "Delivered" => "success",
                                            "In Progress" or "Assigned" => "primary",
                                            "Testing" => "warning",
                                            _ => "secondary"
                                        };
                                        <li>
                                            <form method="post" action="/Admin/UpdateJobStatus">
                                                <input type="hidden" name="id" value="@j.J_id" />
                                                <input type="hidden" name="status" value="@s" />
                                                <button type="submit"
                                                        class="dropdown-item fw-bold text-@sc2 rounded @(j.Status == s ? $"bg-{sc2} bg-opacity-10" : "") mb-1"
                                                        style="font-size:0.85rem;">
                                                    @s
                                                </button>
                                            </form>
                                        </li>
                                    }
                                </ul>
                            </div>
                        </td>
                        <td class="text-center pe-5">
                            <form method="post" action="/Admin/DeleteJobCard" class="d-inline"
                                  onsubmit="return confirm('Delete job card #@j.J_id?')">
                                <input type="hidden" name="id" value="@j.J_id" />
                                <button class="btn btn-sm btn-light text-danger rounded-circle shadow-sm"
                                        style="width:38px;height:38px;" title="Delete">
                                    <i class="fa-solid fa-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="8" class="text-center text-muted py-5">No job cards found.</td></tr>
                }
            </tbody>
        </table>
    </div>
    <div class="p-4 border-top border-light">
        <span class="text-muted fw-medium">@Model.Count record(s)</span>
    </div>
</div>

<!-- Create Job Card Modal -->
<div class="modal fade" id="createJobModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0">
            <div class="modal-header">
                <h5 class="modal-title d-flex align-items-center fs-4">
                    <div class="bg-primary bg-opacity-10 text-primary rounded p-2 me-3">
                        <i class="fa-solid fa-clipboard-list"></i>
                    </div>
                    Create Job Card
                </h5>
                <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" action="/Admin/AddJobCard">
                <div class="modal-body p-4">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="custom-label"><i class="fa-solid fa-car"></i> Vehicle</label>
                            <select name="Vech_id" class="form-select fw-bold" required>
                                <option value="" disabled selected>Select vehicle...</option>
                                @foreach (var v in vehicles)
                                {
                                    <option value="@v.Vech_id">@v.Vech_id — @v.Car_Name @v.Car_Model</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="custom-label"><i class="fa-solid fa-user-gear"></i> Mechanic</label>
                            <select name="Mech_Name" class="form-select fw-bold" required>
                                <option value="" disabled selected>Select mechanic...</option>
                                @foreach (var m in mechanics)
                                {
                                    <option value="@m.Mech_Name">@m.Mech_Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="custom-label"><i class="fa-solid fa-triangle-exclamation text-danger"></i> Problem / Issues</label>
                            <!-- Hidden input that gets filled by JS -->
                            <input type="hidden" name="Problem" id="problemValue">
                            <div class="border rounded-3 p-3" style="background:#f8fafc;">
                                <div class="row g-2">
                                    @foreach (var prob in new[] {
                                        new { icon="fa-oil-can",       label="Oil Change",          color="warning" },
                                        new { icon="fa-car-battery",   label="Battery Issue",       color="danger"  },
                                        new { icon="fa-circle-stop",   label="Brake Problem",       color="danger"  },
                                        new { icon="fa-temperature-high", label="Engine Overheating", color="danger" },
                                        new { icon="fa-tire",          label="Tyre Puncture",       color="secondary" },
                                        new { icon="fa-wind",          label="AC Not Working",      color="info"    },
                                        new { icon="fa-gear",          label="Gearbox Issue",       color="warning" },
                                        new { icon="fa-bolt",          label="Electrical Fault",    color="warning" },
                                        new { icon="fa-droplet",       label="Coolant Leak",        color="info"    },
                                        new { icon="fa-screwdriver-wrench", label="General Service", color="primary" },
                                        new { icon="fa-car-crash",     label="Suspension Issue",    color="secondary" },
                                        new { icon="fa-gauge-high",    label="Engine Noise",        color="danger"  }
                                    })
                                    {
                                        <div class="col-md-4 col-6">
                                            <label class="d-flex align-items-center gap-2 p-2 rounded-3 border bg-white problem-check" style="cursor:pointer;transition:all 0.2s;">
                                                <input type="checkbox" class="prob-cb form-check-input mt-0 flex-shrink-0"
                                                       value="@prob.label" onchange="updateProblems()">
                                                <i class="fa-solid @prob.icon text-@prob.color" style="font-size:0.9rem;width:16px;"></i>
                                                <span class="fw-medium text-dark" style="font-size:0.82rem;">@prob.label</span>
                                            </label>
                                        </div>
                                    }
                                </div>
                                <div class="mt-3">
                                    <label class="custom-label mb-1" style="font-size:0.78rem;"><i class="fa-solid fa-pen me-1"></i> Other / Additional Details</label>
                                    <input type="text" id="otherProblem" class="form-control" placeholder="Describe any other issue..." maxlength="100" oninput="updateProblems()">
                                </div>
                                <div class="mt-2" id="problemPreview" style="display:none;">
                                    <small class="text-muted fw-semibold">Selected: </small>
                                    <small class="text-primary fw-bold" id="problemPreviewText"></small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="custom-label"><i class="fa-regular fa-calendar-plus text-primary"></i> Date In</label>
                            <input type="date" name="Date_in" class="form-control fw-bold" required>
                        </div>
                        <div class="col-md-6">
                            <label class="custom-label"><i class="fa-regular fa-calendar-check text-success"></i> Date Out</label>
                            <input type="date" name="Date_out" class="form-control fw-bold">
                        </div>
                        <div class="col-12">
                            <label class="custom-label"><i class="fa-solid fa-bars-progress text-warning"></i> Status</label>
                            <select name="Status" class="form-select fw-bold">
                                <option value="Pending" selected>Pending</option>
                                <option value="Assigned">Assigned</option>
                                <option value="In Progress">In Progress</option>
                                <option value="Testing">Testing</option>
                                <option value="Completed">Completed</option>
                                <option value="Delivered">Delivered</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 pb-4">
                    <button type="button" class="btn btn-light rounded-pill px-4 fw-bold" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-animated rounded-pill px-5">
                        <i class="fa-solid fa-play me-2"></i> Dispatch Job
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .table-hover tbody tr:hover { background-color:#f8fafc; }
    .dropdown-menu { position: fixed !important; }
    .problem-check:hover { background: #eff6ff !important; border-color: #93c5fd !important; }
    .problem-check input[type=checkbox] { width:16px; height:16px; }
</style>

@section Scripts {
<script>
    // Reposition dropdown to fixed position on show
    document.querySelectorAll('[data-bs-toggle="dropdown"]').forEach(btn => {
        btn.addEventListener('shown.bs.dropdown', function () {
            const menu = this.nextElementSibling;
            const rect = this.getBoundingClientRect();
            menu.style.top  = (rect.bottom + 4) + 'px';
            menu.style.left = rect.left + 'px';
        });
    });

    function updateProblems() {
        const checked = [...document.querySelectorAll('.prob-cb:checked')].map(c => c.value);
        const other   = document.getElementById('otherProblem').value.trim();
        if (other) checked.push(other);

        const combined = checked.join(', ');
        document.getElementById('problemValue').value = combined;

        const preview = document.getElementById('problemPreview');
        const previewText = document.getElementById('problemPreviewText');
        if (combined) {
            preview.style.display = 'block';
            previewText.textContent = combined;
        } else {
            preview.style.display = 'none';
        }
    }

    // Highlight checked labels
    document.addEventListener('change', function(e) {
        if (e.target.classList.contains('prob-cb')) {
            const label = e.target.closest('.problem-check');
            if (e.target.checked) {
                label.style.background = '#eff6ff';
                label.style.borderColor = '#3b82f6';
            } else {
                label.style.background = 'white';
                label.style.borderColor = '';
            }
        }
    });

    // Reset checkboxes when modal closes
    document.getElementById('createJobModal').addEventListener('hidden.bs.modal', function () {
        document.querySelectorAll('.prob-cb').forEach(cb => {
            cb.checked = false;
            cb.closest('.problem-check').style.background = 'white';
            cb.closest('.problem-check').style.borderColor = '';
        });
        document.getElementById('otherProblem').value = '';
        document.getElementById('problemValue').value = '';
        document.getElementById('problemPreview').style.display = 'none';
    });
</script>
}
