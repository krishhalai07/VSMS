@{
    ViewData["Title"] = "Job Cards";
    Layout = "~/Views/Admin/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-5">
    <div>
        <h1 class="page-header mb-1">Active Job Cards</h1>
        <p class="text-muted"><i class="fa-solid fa-clipboard-list me-2 text-primary"></i>Track ongoing repairs and workshop tasks</p>
    </div>
    <button type="button" class="btn-animated" data-bs-toggle="modal" data-bs-target="#createJobModal">
        <i class="fa-solid fa-file-circle-plus me-2"></i> Create Job Card
    </button>
</div>

<div class="card-clean mb-5 p-0">
    <!-- Rest of table omitted for brevity since layout handles it -->
    <div class="table-responsive p-0">
        <table class="table table-hover table-custom mb-0 align-middle">
            <thead class="bg-light text-muted text-uppercase fw-bold" style="font-size: 0.8rem; letter-spacing: 0.5px;">
                <tr>
                    <th class="ps-5 py-3 border-0">Job Ref</th>
                    <th class="py-3 border-0">Client & Vehicle</th>
                    <th class="py-3 border-0">Assigned Tech</th>
                    <th class="py-3 border-0">Services Requested</th>
                    <th class="py-3 border-0">Live Status</th>
                    <th class="text-center pe-5 py-3 border-0">Actions</th>
                </tr>
            </thead>
            <tbody>
                <!-- Job Card 1 -->
                <tr class="border-bottom text-dark">
                    <td class="ps-5 py-4 fw-bold text-primary font-monospace fs-5">JC-1001</td>
                    <td>
                        <div class="d-flex flex-column">
                            <span class="mb-1 fw-bold text-dark"><i class="fa-regular fa-user me-2 text-muted"></i>John Doe</span>
                            <span class="text-muted fw-bold"><i class="fa-solid fa-car-side me-2"></i>Toyota Camry (ABC-1234)</span>
                        </div>
                    </td>
                    <td class="fw-medium text-dark"><i class="fa-solid fa-wrench me-2 text-primary"></i>David Miller</td>
                    <td class="fw-medium text-muted">Standard Maintenance</td>
                    <td>
                        <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 rounded-pill px-3 py-2 fw-bold d-inline-flex align-items-center">
                            <span class="spinner-grow spinner-grow-sm me-2" style="width:0.5rem; height:0.5rem;"></span> IN PROGRESS
                        </span>
                    </td>
                    <td class="text-center pe-5">
                        <button class="btn btn-sm btn-light text-primary rounded-circle shadow-sm me-2 hover-elevate" data-bs-toggle="modal" data-bs-target="#createJobModal" title="Edit Job Card" style="width: 38px; height: 38px;"><i class="fa-solid fa-pen"></i></button>
                        <button class="btn btn-sm btn-light text-danger rounded-circle shadow-sm hover-elevate" data-bs-toggle="modal" data-bs-target="#deleteConfirmationModal" title="Delete Job Card" style="width: 38px; height: 38px;"><i class="fa-solid fa-trash"></i></button>
                    </td>
                </tr>

                <!-- Job Card 2 -->
                <tr class="border-bottom text-dark">
                    <td class="ps-5 py-4 fw-bold text-primary font-monospace fs-5">JC-1002</td>
                    <td>
                        <div class="d-flex flex-column">
                            <span class="mb-1 fw-bold text-dark"><i class="fa-regular fa-user me-2 text-muted"></i>Jane Smith</span>
                            <span class="text-muted fw-bold"><i class="fa-solid fa-car-side me-2"></i>Honda Civic (XYZ-9876)</span>
                        </div>
                    </td>
                    <td class="fw-medium text-dark"><i class="fa-solid fa-wrench me-2 text-primary"></i>Sarah Jenkins</td>
                    <td class="fw-medium text-muted">Brake Pad Swap</td>
                    <td>
                        <span class="badge bg-warning bg-opacity-10 text-warning border border-warning border-opacity-25 rounded-pill px-3 py-2 fw-bold d-inline-flex align-items-center">
                            <i class="fa-solid fa-clock me-2"></i> PENDING PARTS
                        </span>
                    </td>
                    <td class="text-center pe-5">
                        <button class="btn btn-sm btn-light text-primary rounded-circle shadow-sm me-2 hover-elevate" data-bs-toggle="modal" data-bs-target="#createJobModal" title="Edit Job Card" style="width: 38px; height: 38px;"><i class="fa-solid fa-pen"></i></button>
                        <button class="btn btn-sm btn-light text-danger rounded-circle shadow-sm hover-elevate" data-bs-toggle="modal" data-bs-target="#deleteConfirmationModal" title="Delete Job Card" style="width: 38px; height: 38px;"><i class="fa-solid fa-trash"></i></button>
                    </td>
                </tr>

                <!-- Job Card 3 -->
                <tr class="border-bottom text-dark">
                    <td class="ps-5 py-4 fw-bold text-primary font-monospace fs-5">JC-1003</td>
                    <td>
                        <div class="d-flex flex-column">
                            <span class="mb-1 fw-bold text-dark"><i class="fa-regular fa-user me-2 text-muted"></i>Emily Davis</span>
                            <span class="text-muted fw-bold"><i class="fa-solid fa-car-side me-2"></i>Tesla Model 3 (TSL-M3EV)</span>
                        </div>
                    </td>
                    <td class="fw-medium text-dark"><i class="fa-solid fa-wrench me-2 text-primary"></i>Marcus Vance</td>
                    <td class="fw-medium text-muted">Diagnostics Scan</td>
                    <td>
                        <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 rounded-pill px-3 py-2 fw-bold d-inline-flex align-items-center">
                            <i class="fa-solid fa-check-circle me-2"></i> COMPLETED
                        </span>
                    </td>
                    <td class="text-center pe-5">
                        <button class="btn btn-sm btn-light text-primary rounded-circle shadow-sm me-2 hover-elevate" data-bs-toggle="modal" data-bs-target="#createJobModal" title="Edit Job Card" style="width: 38px; height: 38px;"><i class="fa-solid fa-pen"></i></button>
                        <button class="btn btn-sm btn-light text-danger rounded-circle shadow-sm hover-elevate" data-bs-toggle="modal" data-bs-target="#deleteConfirmationModal" title="Delete Job Card" style="width: 38px; height: 38px;"><i class="fa-solid fa-trash"></i></button>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="createJobModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0">
            <div class="modal-header">
                <h5 class="modal-title d-flex align-items-center fs-4">
                    <div class="bg-primary bg-opacity-10 text-primary rounded p-2 me-3">
                        <i class="fa-solid fa-clipboard-list"></i>
                    </div>
                    Generate Job Card
                </h5>
                <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            
            <div class="modal-body p-4 pt-4">
                <form>
                    <div class="row g-4">
                        <div class="col-md-6" style="animation: slideUpFade 0.4s both 0.1s;">
                            <div>
                                <label for="jobVehicle" class="custom-label"><i class="fa-solid fa-car"></i>Target Vehicle</label>
                                <select class="form-select fw-bold text-dark" id="jobVehicle" required>
                                    <option value="" selected disabled>Select Vehicle...</option>
                                    <option value="1">Toyota Camry (ABC-1234)</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-6" style="animation: slideUpFade 0.4s both 0.2s;">
                            <div>
                                <label for="jobMech" class="custom-label"><i class="fa-solid fa-wrench"></i>Assigned Technician</label>
                                <select class="form-select fw-bold text-dark" id="jobMech" required>
                                    <option value="" selected disabled>Unassigned...</option>
                                    <option value="1">David Miller</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-12" style="animation: slideUpFade 0.4s both 0.3s;">
                            <label class="custom-label mb-3 d-block"><i class="fa-solid fa-list-check"></i>Required Services</label>
                            <div class="d-flex gap-3 flex-wrap">
                                <div class="form-check p-0">
                                    <input type="checkbox" class="btn-check" id="chkOil" autocomplete="off" checked>
                                    <label class="btn btn-outline-primary border-2 fw-bold text-sm px-4 rounded-pill transition-hover" for="chkOil">Oil Change</label>
                                </div>
                                <div class="form-check p-0">
                                    <input type="checkbox" class="btn-check" id="chkDiag" autocomplete="off">
                                    <label class="btn btn-outline-primary border-2 fw-bold text-sm px-4 rounded-pill transition-hover" for="chkDiag">Diagnostics</label>
                                </div>
                            </div>
                        </div>
                        <div class="col-12 mt-4" style="animation: slideUpFade 0.4s both 0.4s;">
                            <div>
                                <label for="jobNotes" class="custom-label"><i class="fa-solid fa-note-sticky"></i>Additional Instructions</label>
                                <textarea class="form-control" id="jobNotes" placeholder="Mechanic notes here..." style="height: 100px;"></textarea>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer border-0 pb-4 pt-2">
                <button type="button" class="btn btn-light rounded-pill px-4 fw-bold me-2" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-animated rounded-pill px-5"><i class="fa-solid fa-play me-2"></i> Dispatch Job</button>
            </div>
        </div>
    </div>
</div>

<style>
    .hover-elevate:hover { transform: translateY(-3px); box-shadow: 0 4px 10px rgba(0,0,0,0.1) !important;}
    .hover-lift:hover { background: white; transform: translateY(-1px); box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); }
    .table-hover tbody tr:hover { background-color: #f8fafc; transform: scale(1.005); box-shadow: 0 4px 10px rgba(0,0,0,0.02); transition: all 0.2s; }
    .transition-hover { transition: all 0.2s ease; }
    .btn-check:checked + .btn-outline-primary { box-shadow: 0 4px 15px rgba(67, 56, 202, 0.3) !important; transform: translateY(-2px); }
</style>
