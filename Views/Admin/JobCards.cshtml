@{
    ViewData["Title"] = "Job Cards";
    Layout = "~/Views/Admin/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-5">
    <div>
        <h1 class="page-header mb-1">Active Job Cards</h1>
        <p class="text-muted"><i class="fa-solid fa-clipboard-list me-2 text-primary"></i>Track ongoing repairs and workshop tasks</p>
    </div>
    <button type="button" class="btn-animated" data-bs-toggle="modal" data-bs-target="#createJobModal">
        <i class="fa-solid fa-file-circle-plus me-2"></i> Create Job Card
    </button>
</div>

<div class="card-clean mb-5 p-0">
    <div class="table-responsive p-0" style="overflow-x: visible;">
        <table class="table table-hover table-custom mb-0 align-middle">
            <thead class="bg-light text-muted text-uppercase fw-bold" style="font-size: 0.8rem; letter-spacing: 0.5px;">
                <tr>
                    <th class="ps-5 py-3 border-0">J_id</th>
                    <th class="py-3 border-0">Vech_id</th>
                    <th class="py-3 border-0">Problem</th>
                    <th class="py-3 border-0">Date_in</th>
                    <th class="py-3 border-0">Date_out</th>
                    <th class="py-3 border-0">Mech_Name</th>
                    <th class="py-3 border-0">Status</th>
                    <th class="text-center pe-5 py-3 border-0">Actions</th>
                </tr>
            </thead>
            <tbody>
                <!-- Job Card 1 -->
                <tr class="border-bottom text-dark">
                    <td class="ps-5 py-4 fw-bold text-primary font-monospace fs-5">1001</td>
                    <td class="fw-bold">1</td>
                    <td class="text-muted fw-medium">Standard Maintenance</td>
                    <td class="text-muted">2026-03-25</td>
                    <td class="text-muted">2026-03-26</td>
                    <td class="fw-medium text-dark"><i class="fa-solid fa-wrench me-2 text-primary"></i>David Miller</td>
                    <td>
                        <div class="dropdown">
                            <button class="btn btn-sm fw-bold border-0 shadow-sm bg-primary bg-opacity-10 text-primary dropdown-toggle d-flex justify-content-between align-items-center" type="button" data-bs-toggle="dropdown" aria-expanded="false" style="width: 140px; border-radius: 8px;">
                                In Progress
                            </button>
                            <ul class="dropdown-menu shadow-lg border-0 p-2 bg-white" style="border-radius: 12px; min-width: 140px; z-index: 1050;">
                                <li><a class="dropdown-item fw-bold text-secondary rounded transition-hover mb-1" href="#" onclick="updateJobStatus(event, this, 'Pending', 'secondary')">Pending</a></li>
                                <li><a class="dropdown-item fw-bold text-info rounded transition-hover mb-1" href="#" onclick="updateJobStatus(event, this, 'Assigned', 'info')">Assigned</a></li>
                                <li><a class="dropdown-item fw-bold text-primary rounded bg-primary bg-opacity-10 mb-1" href="#" onclick="updateJobStatus(event, this, 'In Progress', 'primary')">In Progress</a></li>
                                <li><a class="dropdown-item fw-bold text-warning rounded transition-hover mb-1" href="#" onclick="updateJobStatus(event, this, 'Testing', 'warning')">Testing</a></li>
                                <li><a class="dropdown-item fw-bold text-success rounded transition-hover mb-1" href="#" onclick="updateJobStatus(event, this, 'Completed', 'success')">Completed</a></li>
                                <li><a class="dropdown-item fw-bold text-dark rounded transition-hover mb-1" href="#" onclick="updateJobStatus(event, this, 'Ready', 'dark')">Ready</a></li>
                                <li><a class="dropdown-item fw-bold text-success rounded transition-hover" href="#" onclick="updateJobStatus(event, this, 'Delivered', 'success')">Delivered</a></li>
                            </ul>
                        </div>
                    </td>
                    <td class="text-center pe-5">
                        <button class="btn btn-sm btn-light text-primary rounded-circle shadow-sm me-2 hover-elevate" data-bs-toggle="modal" data-bs-target="#createJobModal" title="Edit Job Card" style="width: 38px; height: 38px;"><i class="fa-solid fa-pen"></i></button>
                        <button class="btn btn-sm btn-light text-danger rounded-circle shadow-sm hover-elevate" data-bs-toggle="modal" data-bs-target="#deleteConfirmationModal" title="Delete Job Card" style="width: 38px; height: 38px;"><i class="fa-solid fa-trash"></i></button>
                    </td>
                </tr>

                <!-- Job Card 2 -->
                <tr class="border-bottom text-dark">
                    <td class="ps-5 py-4 fw-bold text-primary font-monospace fs-5">1002</td>
                    <td class="fw-bold">2</td>
                    <td class="text-muted fw-medium">Brake Pad Swap</td>
                    <td class="text-muted">2026-03-26</td>
                    <td class="text-muted">-</td>
                    <td class="fw-medium text-dark"><i class="fa-solid fa-wrench me-2 text-primary"></i>Sarah Jenkins</td>
                    <td>
                        <div class="dropdown">
                            <button class="btn btn-sm fw-bold border-0 shadow-sm bg-secondary bg-opacity-10 text-secondary dropdown-toggle d-flex justify-content-between align-items-center" type="button" data-bs-toggle="dropdown" aria-expanded="false" style="width: 140px; border-radius: 8px;">
                                Pending
                            </button>
                            <ul class="dropdown-menu shadow-lg border-0 p-2 bg-white" style="border-radius: 12px; min-width: 140px; z-index: 1050;">
                                <li><a class="dropdown-item fw-bold text-secondary rounded bg-secondary bg-opacity-10 mb-1" href="#" onclick="updateJobStatus(event, this, 'Pending', 'secondary')">Pending</a></li>
                                <li><a class="dropdown-item fw-bold text-info rounded transition-hover mb-1" href="#" onclick="updateJobStatus(event, this, 'Assigned', 'info')">Assigned</a></li>
                                <li><a class="dropdown-item fw-bold text-primary rounded transition-hover mb-1" href="#" onclick="updateJobStatus(event, this, 'In Progress', 'primary')">In Progress</a></li>
                                <li><a class="dropdown-item fw-bold text-warning rounded transition-hover mb-1" href="#" onclick="updateJobStatus(event, this, 'Testing', 'warning')">Testing</a></li>
                                <li><a class="dropdown-item fw-bold text-success rounded transition-hover mb-1" href="#" onclick="updateJobStatus(event, this, 'Completed', 'success')">Completed</a></li>
                                <li><a class="dropdown-item fw-bold text-dark rounded transition-hover mb-1" href="#" onclick="updateJobStatus(event, this, 'Ready', 'dark')">Ready</a></li>
                                <li><a class="dropdown-item fw-bold text-success rounded transition-hover" href="#" onclick="updateJobStatus(event, this, 'Delivered', 'success')">Delivered</a></li>
                            </ul>
                        </div>
                    </td>
                    <td class="text-center pe-5">
                        <button class="btn btn-sm btn-light text-primary rounded-circle shadow-sm me-2 hover-elevate" data-bs-toggle="modal" data-bs-target="#createJobModal" title="Edit Job Card" style="width: 38px; height: 38px;"><i class="fa-solid fa-pen"></i></button>
                        <button class="btn btn-sm btn-light text-danger rounded-circle shadow-sm hover-elevate" data-bs-toggle="modal" data-bs-target="#deleteConfirmationModal" title="Delete Job Card" style="width: 38px; height: 38px;"><i class="fa-solid fa-trash"></i></button>
                    </td>
                </tr>

                <!-- Job Card 3 -->
                <tr class="border-bottom text-dark">
                    <td class="ps-5 py-4 fw-bold text-primary font-monospace fs-5">1003</td>
                    <td class="fw-bold">3</td>
                    <td class="text-muted fw-medium">Diagnostics Scan</td>
                    <td class="text-muted">2026-03-24</td>
                    <td class="text-muted">2026-03-24</td>
                    <td class="fw-medium text-dark"><i class="fa-solid fa-wrench me-2 text-primary"></i>Marcus Vance</td>
                    <td>
                        <div class="dropdown">
                            <button class="btn btn-sm fw-bold border-0 shadow-sm bg-success bg-opacity-10 text-success dropdown-toggle d-flex justify-content-between align-items-center" type="button" data-bs-toggle="dropdown" aria-expanded="false" style="width: 140px; border-radius: 8px;">
                                Completed
                            </button>
                            <ul class="dropdown-menu shadow-lg border-0 p-2 bg-white" style="border-radius: 12px; min-width: 140px; z-index: 1050;">
                                <li><a class="dropdown-item fw-bold text-secondary rounded transition-hover mb-1" href="#" onclick="updateJobStatus(event, this, 'Pending', 'secondary')">Pending</a></li>
                                <li><a class="dropdown-item fw-bold text-info rounded transition-hover mb-1" href="#" onclick="updateJobStatus(event, this, 'Assigned', 'info')">Assigned</a></li>
                                <li><a class="dropdown-item fw-bold text-primary rounded transition-hover mb-1" href="#" onclick="updateJobStatus(event, this, 'In Progress', 'primary')">In Progress</a></li>
                                <li><a class="dropdown-item fw-bold text-warning rounded transition-hover mb-1" href="#" onclick="updateJobStatus(event, this, 'Testing', 'warning')">Testing</a></li>
                                <li><a class="dropdown-item fw-bold text-success rounded bg-success bg-opacity-10 mb-1" href="#" onclick="updateJobStatus(event, this, 'Completed', 'success')">Completed</a></li>
                                <li><a class="dropdown-item fw-bold text-dark rounded transition-hover mb-1" href="#" onclick="updateJobStatus(event, this, 'Ready', 'dark')">Ready</a></li>
                                <li><a class="dropdown-item fw-bold text-success rounded transition-hover" href="#" onclick="updateJobStatus(event, this, 'Delivered', 'success')">Delivered</a></li>
                            </ul>
                        </div>
                    </td>
                    <td class="text-center pe-5">
                        <button class="btn btn-sm btn-light text-primary rounded-circle shadow-sm me-2 hover-elevate" data-bs-toggle="modal" data-bs-target="#createJobModal" title="Edit Job Card" style="width: 38px; height: 38px;"><i class="fa-solid fa-pen"></i></button>
                        <button class="btn btn-sm btn-light text-danger rounded-circle shadow-sm hover-elevate" data-bs-toggle="modal" data-bs-target="#deleteConfirmationModal" title="Delete Job Card" style="width: 38px; height: 38px;"><i class="fa-solid fa-trash"></i></button>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="createJobModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0">
            <div class="modal-header">
                <h5 class="modal-title d-flex align-items-center fs-4">
                    <div class="bg-primary bg-opacity-10 text-primary rounded p-2 me-3">
                        <i class="fa-solid fa-clipboard-list"></i>
                    </div>
                    Generate Job Card
                </h5>
                <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            
            <div class="modal-body p-4 pt-4">
                <form>
                    <div class="row g-4">
                        <!-- J_id -->
                        <div class="col-md-4" style="animation: slideUpFade 0.4s both 0.1s;">
                            <div>
                                <label for="J_id" class="custom-label"><i class="fa-solid fa-hashtag"></i>Job ID (J_id)</label>
                                <input type="number" class="form-control bg-light" id="J_id" placeholder="Auto" readonly>
                            </div>
                        </div>

                        <!-- Vech_id -->
                        <div class="col-md-8" style="animation: slideUpFade 0.4s both 0.1s;">
                            <div>
                                <label for="Vech_id" class="custom-label"><i class="fa-solid fa-car"></i>Vehicle ID (Vech_id)</label>
                                <select class="form-select fw-bold text-dark" id="Vech_id" required>
                                    <option value="" selected disabled>Select assigned vehicle...</option>
                                    <option value="1">1 - Toyota Camry (ABC-1234)</option>
                                    <option value="2">2 - Honda Civic (XYZ-9876)</option>
                                </select>
                            </div>
                        </div>

                        <!-- Problem -->
                        <div class="col-12" style="animation: slideUpFade 0.4s both 0.2s;">
                            <div>
                                <label for="Problem" class="custom-label"><i class="fa-solid fa-triangle-exclamation text-danger"></i>Problem Description</label>
                                <input type="text" class="form-control" id="Problem" placeholder="Brief issue description (max 50 chars)" maxlength="50" required>
                            </div>
                        </div>

                        <!-- Date_in & Date_out -->
                        <div class="col-md-6" style="animation: slideUpFade 0.4s both 0.3s;">
                            <div>
                                <label for="Date_in" class="custom-label"><i class="fa-regular fa-calendar-plus text-primary"></i>Date In</label>
                                <input type="date" class="form-control text-muted fw-bold" id="Date_in" required>
                            </div>
                        </div>
                        <div class="col-md-6" style="animation: slideUpFade 0.4s both 0.3s;">
                            <div>
                                <label for="Date_out" class="custom-label"><i class="fa-regular fa-calendar-check text-success"></i>Date Out</label>
                                <input type="date" class="form-control text-muted fw-bold" id="Date_out">
                            </div>
                        </div>

                        <!-- Mech_Name & Status -->
                        <div class="col-md-6" style="animation: slideUpFade 0.4s both 0.4s;">
                            <div>
                                <label for="Mech_Name" class="custom-label"><i class="fa-solid fa-user-gear"></i>Mechanic Name</label>
                                <input type="text" class="form-control" id="Mech_Name" placeholder="e.g. David Miller" maxlength="50" required>
                            </div>
                        </div>
                        <div class="col-md-6" style="animation: slideUpFade 0.4s both 0.4s;">
                            <div>
                                <label for="Status" class="custom-label"><i class="fa-solid fa-bars-progress text-warning"></i>Job Status</label>
                                <select class="form-select fw-bold text-dark" id="Status" required>
                                    <option value="Pending" selected>Pending</option>
                                    <option value="Assigned">Assigned</option>
                                    <option value="In Progress">In Progress</option>
                                    <option value="Testing">Testing</option>
                                    <option value="Completed">Completed</option>
                                    <option value="Ready">Ready</option>
                                    <option value="Delivered">Delivered</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer border-0 pb-4 pt-2">
                <button type="button" class="btn btn-light rounded-pill px-4 fw-bold me-2" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-animated rounded-pill px-5"><i class="fa-solid fa-play me-2"></i> Dispatch Job</button>
            </div>
        </div>
    </div>
</div>

    <style>
        .hover-elevate:hover { transform: translateY(-3px); box-shadow: 0 4px 10px rgba(0,0,0,0.1) !important;}
        .hover-lift:hover { background: white; transform: translateY(-1px); box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); }
        .table-hover tbody tr:hover { background-color: #f8fbfd; transition: background-color 0.2s; }
        .transition-hover { transition: all 0.15s ease-in-out; }
        .btn-check:checked + .btn-outline-primary { box-shadow: 0 4px 15px rgba(67, 56, 202, 0.3) !important; transform: translateY(-2px); }
        .custom-dropdown-btn::after { margin-left: auto; }
        .transition-hover:hover { background-color: #f1f5f9; color: #0f172a !important; transform: translateX(2px); }
    </style>

@section Scripts {
    <script>
        function updateJobStatus(e, element, status, colorClass) {
            e.preventDefault();
            const btn = element.closest('.dropdown').querySelector('.dropdown-toggle');
            const menuItems = element.closest('.dropdown-menu').querySelectorAll('.dropdown-item');
            
            // Revert all item classes
            menuItems.forEach(item => {
                let originalClasses = item.className;
                item.className = originalClasses.replace(/bg-[a-z]+ bg-opacity-10/g, 'transition-hover');
            });

            // Set button appearance
            btn.className = `btn btn-sm fw-bold border-0 shadow-sm bg-${colorClass} bg-opacity-10 text-${colorClass} dropdown-toggle d-flex justify-content-between align-items-center`;
            btn.innerText = status;
            
            // Set newly clicked item appearance
            element.className = element.className.replace('transition-hover', `bg-${colorClass} bg-opacity-10`);
            
            if (typeof showToast === 'function') {
                showToast(`Job status updated to ${status}`, colorClass === 'danger' ? 'danger' : 'success');
            }

            // Automatically close the dropdown menu after selection
            const dropdownInstance = bootstrap.Dropdown.getOrCreateInstance(btn);
            if (dropdownInstance) {
                dropdownInstance.hide();
            }
        }
    </script>
}
