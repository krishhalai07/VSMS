@{
    ViewData["Title"] = "Reports";
    Layout = "~/Views/Admin/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-5">
    <div>
        <h1 class="page-header mb-1">Analytics Sandbox</h1>
        <p class="text-muted"><i class="fa-solid fa-chart-pie me-2 text-primary"></i>Global telemetry, financial influx, and operational projections</p>
    </div>
    <div>
        <button class="btn btn-light bg-white border fw-bold rounded-pill px-4 text-dark shadow-sm me-2 hover-elevate"><i class="fa-solid fa-calendar me-2"></i> Date Matrix</button>
        <button class="btn-animated"><i class="fa-solid fa-download me-2"></i> Fetch Raw Data</button>
    </div>
</div>

<div class="row g-4 mb-5">
    <div class="col-12">
        <div class="card-clean p-4 h-100">
            <h4 class="fw-bold text-dark mb-4 border-bottom border-light pb-3"><i class="fa-solid fa-ranking-star me-2 text-warning"></i>Top Performing Operatives</h4>
            
            <div class="d-flex align-items-center p-3 rounded-4 mb-3 bg-light border transition-hover">
                <div class="fs-4 fw-bold me-4" style="color: #f59e0b;">#1</div>
                <img src="https://ui-avatars.com/api/?name=David+Miller&background=e0e7ff&color=4338ca&bold=true" class="rounded-circle me-3 border border-2 border-white shadow-sm" width="50">
                <div class="flex-grow-1">
                    <h6 class="fw-bold text-dark mb-0">David Miller</h6>
                    <small class="text-muted fw-medium">Engine Specialist</small>
                </div>
                <div class="text-end">
                    <h5 class="fw-bolder text-primary mb-0">42</h5>
                    <small class="text-muted fw-bold">Jobs Closed</small>
                </div>
            </div>

            <div class="d-flex align-items-center p-3 rounded-4 mb-3 bg-light border transition-hover">
                <div class="fs-4 fw-bold me-4 text-secondary">#2</div>
                <img src="https://ui-avatars.com/api/?name=Robert+Chen&background=fef3c7&color=d97706&bold=true" class="rounded-circle me-3 border border-2 border-white shadow-sm" width="50">
                <div class="flex-grow-1">
                    <h6 class="fw-bold text-dark mb-0">Robert Chen</h6>
                    <small class="text-muted fw-medium">Electrical Systems</small>
                </div>
                <div class="text-end">
                    <h5 class="fw-bolder text-primary mb-0">38</h5>
                    <small class="text-muted fw-bold">Jobs Closed</small>
                </div>
            </div>
            
            <div class="d-flex align-items-center p-3 rounded-4 bg-light border transition-hover">
                <div class="fs-4 fw-bold me-4" style="color:#cd7f32;">#3</div>
                <img src="https://ui-avatars.com/api/?name=Carlos+S&background=fce7f3&color=be185d&bold=true" class="rounded-circle me-3 border border-2 border-white shadow-sm" width="50">
                <div class="flex-grow-1">
                    <h6 class="fw-bold text-dark mb-0">Carlos Santana</h6>
                    <small class="text-muted fw-medium">General Service</small>
                </div>
                <div class="text-end">
                    <h5 class="fw-bolder text-primary mb-0">29</h5>
                    <small class="text-muted fw-bold">Jobs Closed</small>
                </div>
            </div>
            
        </div>
    </div>
</div>

<style>
    .letter-spacing-1 { letter-spacing: 1px; }
    .text-sm { font-size: 0.875rem; }
    .hover-elevate:hover { transform: translateY(-3px); box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;}
    .transition-hover { transition: all 0.3s ease; }
    .transition-hover:hover { background: white !important; transform: translateX(5px); box-shadow: 0 5px 15px rgba(0,0,0,0.05); border-color: #cbd5e1 !important; }
</style>
