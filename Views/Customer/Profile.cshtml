@model VSMS.Models.Customer
@{
    ViewData["Title"] = "My Profile";
    Layout = "~/Views/Customer/_Layout.cshtml";
}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">
            <div class="glass-card" data-aos="zoom-in">
                <div style="background:linear-gradient(135deg,#2563eb,#1e40af);padding:40px 20px 80px;text-align:center;border-radius:16px 16px 0 0;position:relative;">
                    <h3 class="fw-bold text-white mb-1">My Profile</h3>
                    <p class="text-white-50 mb-0">Your account information</p>
                    <img src="https://ui-avatars.com/api/?name=@Uri.EscapeDataString(Model?.Name ?? "User")&background=2563eb&color=fff&bold=true&size=120"
                         class="rounded-circle border border-4 border-white shadow"
                         style="width:100px;height:100px;position:absolute;bottom:-50px;left:50%;transform:translateX(-50%);" />
                </div>
                <div style="padding:70px 40px 40px;text-align:center;">
                    <h4 class="fw-bold text-dark mb-1">@Model?.Name</h4>
                    <p class="text-muted mb-4">Customer #@Model?.Customer_id</p>
                    <div class="text-start">
                        <div class="d-flex align-items-center p-3 bg-light rounded-3 mb-3 border">
                            <div class="text-primary me-3" style="width:40px;text-align:center;"><i class="fa-solid fa-envelope fs-5"></i></div>
                            <div>
                                <div class="text-muted" style="font-size:0.78rem;font-weight:600;text-transform:uppercase;">Email</div>
                                <div class="fw-bold text-dark">@Model?.Email</div>
                            </div>
                        </div>
                        <div class="d-flex align-items-center p-3 bg-light rounded-3 mb-3 border">
                            <div class="text-success me-3" style="width:40px;text-align:center;"><i class="fa-solid fa-phone fs-5"></i></div>
                            <div>
                                <div class="text-muted" style="font-size:0.78rem;font-weight:600;text-transform:uppercase;">Contact</div>
                                <div class="fw-bold text-dark">@Model?.Contact</div>
                            </div>
                        </div>
                    </div>
                    <a href="/Customer/Logout" class="btn btn-outline-danger rounded-pill px-4 mt-3 fw-bold">
                        <i class="fa-solid fa-arrow-right-from-bracket me-2"></i>Logout
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
